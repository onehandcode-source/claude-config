ame}")          # 의존성 관계     depend_edges = [e for e in related_edges if 'depend' in e.get('relation', '').lower()]     if depend_edges:         print(f"\n의존성 관계(depends-on): {len(depend_edges)}개")         for i, edge in enumerate(depend_edges[:5]):             from_name = edge.get('from', '').split(':')[-1]             to_name = edge.get('to', '').split(':')[-1]             print(f"  [{i+1}] {from_name} -> {to_name}")  # AutoClsfDTO 필드 구조 print("\n" + "=" * 90) print("6. AutoClsfDTO 데이터 구조") print("=" * 90)  auto_clsf_dto = None if 'nodes' in data:     for node in data['nodes']:         if node.get('name') == 'AutoClsfDTO' and node.get('type') == 'class':             auto_clsf_dto = node             break  if auto_clsf_dto:     print(f"\n클래스: {auto_clsf_dto.get('name')}")     print(f"파일: {auto_clsf_dto.get('filePath')}")     print(f"\n설명: {auto_clsf_dto.get('summary')}")     if auto_clsf_dto.get('tags'):         print(f"태그: {', '.join(auto_clsf_dto.get('tags', []))}")  # SafeReportService 주요 메서드 print("\n" + "=" * 90) print("7. SafeReportService 주요 메서드") print("=" * 90)  safe_report_service = None safe_report_methods = []  if 'nodes' in data:     for node in data['nodes']:         if node.get('name') == 'SafeReportServiceImpl' and node.get('type') == 'class':             safe_report_service = node         if 'SafeReportServiceImpl.java' in node.get('id', '') and node.get('type') == 'function':             safe_report_methods.append(node)  if safe_report_service:     print(f"\n클래스: {safe_report_service.get('name')}")     print(f"설명: {safe_report_service.get('summary')[:120]}")  print(f"\n주요 메서드 ({len(safe_report_methods)}개 중 상위 12개):") for i, method in enumerate(safe_report_methods[:12]):     print(f"\n  [{i+1}] {method.get('name')}")     if method.get('summary'):         print(f"      {method.get('summary')[:80]}")  EOF 
[2026-05-28T08:50:39.329Z] tool=Bash command=cd "/c/Dev/dev_safetyreport/workspace/portal" && python3 << 'EOF' import json import sys  sys.stdout.reconfigure(encoding='utf-8')  with open('.understand-anything/knowledge-graph.json', 'r', encoding='utf-8') as f:     data = json.load(f)  # 최종 요약 print("=" * 100) print("안전신문고 포털 - 자동분류(AutoClassification) 시스템 분석 보고서") print("=" * 100)  print("\n" + "=" * 100) print("프로젝트 개요") print("=" * 100)  proj = data.get('project', {}) print(f""" 프로젝트명: {proj.get('name')} 설명: {proj.get('description', 'N/A')[:200]}... 주요 언어: {', '.join(proj.get('languages', []))} 주요 프레임워크: {', '.join(proj.get('frameworks', []))} 분석 날짜: {proj.get('analyzedAt')} Git Commit Hash: {proj.get('gitCommitHash')} """)  # 자동분류 관련 핵심 구성 print("=" * 100) print("1. 자동분류(AutoClassification) 시스템 구조") print("=" * 100)  print(""" 자동분류는 신고자의 신고 내용, 주소, 차량 정보 등을 기반으로 자동으로 신고 카테고리와  처리부서를 결정하는 AI 기반 분류 시스템입니다.  ■ 핵심 구현체: AutoClsfServiceImpl   - 패턴매칭(Pattern Matching)   - 정규식(Regular Expression)    - REST 외부호출(External REST Service)   을 통해 신고기관과 분류코드를 결정합니다.  ■ 주요 함수:   1. autoClsfService: 자동분류 메인 진입 메서드      - 사전처리(Preprocessing)      - 핵심분류(Core Classification)      - 결과세팅(Result Setting)을 순차 호출    2. autoClsfCore: 핵심 분류 알고리즘      - 키워드/주소/차량 정보를 종합 판단      - 신고 카테고리(ssnpcCd) 결정    3. searchPattern: 신고 본문 패턴 매칭 분류      - 정규식을 통한 키워드 기반 분류    4. sendREST: 외부 자동분류 REST 서비스 호출      - 복잡한 분류는 외부 서비스에 위임    5. searchCarAddr: 차량번호 기반 주소/관할 검색      - 차량신고의 주소 정보 보강    6. findByCtgryPrcsDpt: 카테고리·처리부서 매핑 조회      - 결정된 카테고리를 처리부서로 매핑 """)  print("=" * 100) print("2. 자동분류 관련 노드 상세 정보") print("=" * 100)  auto_nodes = [] if 'nodes' in data:     for node in data['nodes']:         if 'AutoClsf' in node.get('id', '') or 'autoClsf' in node.get('id', ''):             auto_nodes.append(node)  print(f"\n■ AutoClsf 관련 노드: {len(auto_nodes)}개\n")  # 파일/클래스/함수별로 분류 files = [n for n in auto_nodes if n.get('type') == 'file'] classes = [n for n in auto_nodes if n.get('type') == 'class'] functions = [n for n in auto_nodes if n.get('type') == 'function']  print(f"파일: {len(files)}개") for f in files:     print(f"  • {f.get('name')}")  print(f"\n클래스/인터페이스: {len(classes)}개") for c in classes:     print(f"  • {c.get('name')}")  print(f"\n함수: {len(functions)}개") for func in functions[:15]:     print(f"  • {func.get('name')}") if len(functions) > 15:     print(f"  ... 외 {len(functions) - 15}개")  print("\n" + "=" * 100) print("3. 신고유형(ReportType) 관련 핵심 클래스") print("=" * 100)  report_types = [     ('SafeReportService', '신고 CRUD 및 처리부서 매핑'),     ('SafeReportController', '신고 REST API 엔드포인트'),     ('SafeReportMapper', '신고 데이터 MyBatis 매퍼'),     ('ApiSafeReportController', '모바일/외부 시스템용 안전신고 API'),     ('OceanSafeReportController', '해양 안전신고 REST API'),     ('MySafeReportService', '마이페이지 신고 관리 서비스'),     ('MySafeReportMapper', '마이페이지 신고 쿼리 매퍼'), ]  for name, desc in report_types:     print(f"  • {name:<35} : {desc}")  print("\n" + "=" * 100) print("4. 분류 데이터 모델 (DTO/VO)") print("=" * 100)  dtos = [] if 'nodes' in data:     for node in data['nodes']:         name = node.get('name', '')         if any(kw in name for kw in ['DTO', 'Vo', 'Entity', 'CodeInfo']):             if node.get('type') == 'class' and any(kw in node.get('id', '') for kw in ['AutoClsf', 'SafeReport', 'Code']):                 dtos.append(node)  print(f"\n발견된 데이터 모델: {len(dtos)}개") for i, dto in enumerate(dtos[:10]):     print(f"\n[{i+1}] {dto.get('name')}")     if dto.get('summary'):         print(f"    {dto.get('summary')[:100]}")  print("\n" + "=" * 100) print("5. 자동분류 흐름도") print("=" * 100)  print(""" [신고 요청]     ↓ [SafeReportController.autoClassification]     ↓ [AutoClsfServiceImpl.autoClassification]     ↓ [AutoClsfServiceImpl.autoClsfService]     ├─→ [preSetProcess] - 입력 정규화 및 필수 필드 보정     │     ├─→ [autoClsfCore] - 핵심 분류 알고리즘     │   ├─→ [searchPattern] - 패턴 매칭 분류     │   ├─→ [searchCarAddr] - 차량번호 기반 주소 검색     │   └─→ [sendREST] - 외부 REST 서비스 호출     │     ├─→ [runAutoClsfElse] - 예외/보완 분류 경로     │   └─→ [autoClsfEnhanced] - 개선된 분류 알고리즘     │     └─→ [findByCtgryPrcsDpt] - 카테고리→처리부서 매핑         ↓     [분류 결과 반환]         ├─→ 신고 카테고리 (ssnpcCd)         ├─→ 처리부서 코드         └─→ 기관 정보 """)  print("\n" + "=" * 100) print("6. 주요 파일 경로 정리") print("=" * 100)  key_files = {     '자동분류 핵심 서비스': [         'src/main/java/kr/go/safepeople/common/autoClsf/service/impl/AutoClsfServiceImpl.java',         'src/main/java/kr/go/safepeople/common/autoClsf/service/AutoClsfService.java',         'src/main/java/kr/go/safepeople/common/autoClsf/dto/AutoClsfDTO.java',         'src/main/java/kr/go/safepeople/common/autoClsf/util/AutoClsfUtil.java',     ],     '자동분류 매퍼': [         'src/main/java/kr/go/safepeople/common/autoClsf/service/mapper/AutoClsfMapper.java',     ],     '신고 컨트롤러': [         'src/main/java/kr/go/safepeople/portal/safereport/controller/SafeReportController.java',         'src/main/java/kr/go/safepeople/portal/safereport/controller/SafeReportNController.java',         'src/main/java/kr/go/safepeople/portal/safereport/controller/ApiSafeReportController.java',     ],     '신고 서비스': [         'src/main/java/kr/go/safepeople/portal/safereport/service/impl/SafeReportServiceImpl.java',         'src/main/java/kr/go/safepeople/portal/safereport/service/mapper/SafeReportMapper.java',     ], }  for category, files_list in key_files.items():     print(f"\n{category}:")     for file_path in files_list:         print(f"  • {file_path}")  print("\n" + "=" * 100) print("7. 통계 정보") print("=" * 100)  print(f""" 총 노드 수: {len(data.get('nodes', []))}개   - 파일: {len([n for n in data.get('nodes', []) if n.get('type') == 'file'])}개   - 클래스: {len([n for n in data.get('nodes', []) if n.get('type') == 'class'])}개   - 함수: {len([n for n in data.get('nodes', []) if n.get('type') == 'function'])}개  AutoClsf 관련 노드: {len([n for n in data.get('nodes', []) if 'AutoClsf' in n.get('id', '')])}개 SafeReport 관련 노드: {len([n for n in data.get('nodes', []) if 'SafeReport' in n.get('id', '')])}개 총 엣지 수: {len(data.get('edges', []))}개 """)  EOF 
