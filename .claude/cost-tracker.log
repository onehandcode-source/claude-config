개의 자동분류 관련 엣지:")     for i, edge in enumerate(auto_edges[:15]):         from_name = edge.get('from', '').split(':')[-1]         to_name = edge.get('to', '').split(':')[-1]         print(f"\n[{i+1}] {from_name} -> {to_name}")         print(f"    Relation: {edge.get('relation', 'N/A')}")  # 4. SafeReport와 관련된 주요 엣지 print("\n" + "=" * 80) print("SafeReport 관련 주요 엣지") print("=" * 80)  if 'edges' in data:     report_edges = []     for edge in data['edges']:         from_id = edge.get('from', '')         to_id = edge.get('to', '')         if ('SafeReport' in from_id or 'SafeReport' in to_id) and ('autoClassif' in from_id or 'autoClassif' in to_id):             report_edges.append(edge)          if report_edges:         print(f"총 {len(report_edges)}개의 SafeReport-autoClassif 엣지:")         for edge in report_edges[:10]:             print(f"\n{edge.get('from', 'N/A')}")             print(f"  -> {edge.get('to', 'N/A')}")             print(f"  ({edge.get('relation', 'N/A')})")     else:         print("(직접 연결된 SafeReport-autoClassif 엣지 없음)")  EOF 
