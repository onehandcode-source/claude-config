### 구성요소 2: Alloy 수집 에이전트 (각 대상 서버)

```alloy
// /etc/alloy/config.alloy

// ① 시스템 메트릭 (DISK / CPU / RAM / 데몬 상태)
prometheus.exporter.unix "node" {
  enable_collectors = ["filesystem", "diskstats", "meminfo", "cpu", "systemd"]
  systemd_unit_include = "nginx.service|tomcat.service|.*app.*"
}

// ② 포트 연결 가능 여부 (방화벽 대체)
prometheus.exporter.blackbox "probe" {
  config = `{ modules: { tcp_connect: { prober: tcp, timeout: "5s" } } }`
  target { name = "app-8080",  address = "localhost:8080", module = "tcp_connect" }
  target { name = "db-5432",   address = "localhost:5432", module = "tcp_connect" }
}

// ③ 메트릭 → Prometheus 전송
prometheus.scrape "local" {
  targets = concat(
    prometheus.exporter.unix.node.targets,
    prometheus.exporter.blackbox.probe.targets,
  )
  forward_to = [prometheus.remote_write.monitoring.receiver]
}

prometheus.remote_write "monitoring" {
  endpoint { url = "http://<모니터링서버IP>:9090/api/v1/push" }
}

// ④ 앱 로그 + 시스템 로그 → Loki 전송
loki.source.file "app_logs" {
  targets = [
    {__path__ = "/var/log/nginx/*.log",  job = "nginx"},
    {__path__ = "/opt/app/logs/*.log",   job = "app"},
  ]
  forward_to = [loki.write.monitoring.receiver]
}

loki.source.journal "journal" {
  forward_to = [loki.write.monitoring.receiver]
}

loki.write "monitoring" {
  endpoint { url = "http://<모니터링서버IP>:3100/loki/api/v1/push" }
}
```

