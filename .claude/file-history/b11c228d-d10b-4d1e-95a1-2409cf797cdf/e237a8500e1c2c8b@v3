## 3. 구성요소 상세

### 구성요소 1: 모니터링 서버 Docker Compose

```yaml
# docker-compose.yml (핵심 구조)
services:
  grafana:
    image: grafana/grafana:10.4.0
    ports: ["3000:3000"]
    volumes:
      - ./grafana/provisioning:/etc/grafana/provisioning
      - grafana-data:/var/lib/grafana

  prometheus:
    image: prom/prometheus:v2.51.0
    ports: ["9090:9090"]
    volumes:
      - ./prometheus/prometheus.yml:/etc/prometheus/prometheus.yml
      - ./prometheus/targets:/etc/prometheus/targets   # file_sd_configs
      - prometheus-data:/prometheus
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --web.enable-lifecycle   # 재시작 없이 설정 reload

  loki:
    image: grafana/loki:3.0.0
    ports: ["3100:3100"]

  ollama:
    image: ollama/ollama:latest
    ports: ["11434:11434"]
    volumes:
      - ./ollama/models:/root/.ollama/models  # 오프라인 모델 파일

  fastapi:
    build: ./ai-service
    ports: ["8000:8000"]
    volumes:
      - ./prometheus/targets:/app/targets     # 수집 대상 JSON 공유

  n8n:
    image: n8nio/n8n:latest
    ports: ["5678:5678"]
    volumes:
      - n8n-data:/home/node/.n8n
```

