<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI 통합 모니터링 — 대시보드</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body { height: 100%; overflow: hidden; }

    body {
      font-family: 'Segoe UI', 'Apple SD Gothic Neo', sans-serif;
      background: #0d1117;
      color: #e6edf3;
      display: flex;
      flex-direction: column;
    }

    /* ── 상단 네비게이션 바 ── */
    .topbar {
      display: flex;
      align-items: center;
      background: #161b22;
      border-bottom: 1px solid #21262d;
      padding: 0 24px;
      height: 52px;
      flex-shrink: 0;
      z-index: 100;
    }

    .topbar-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-right: 32px;
    }
    .topbar-icon {
      width: 28px; height: 28px; border-radius: 7px;
      background: linear-gradient(135deg, #1d4ed8 0%, #7c3aed 100%);
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; flex-shrink: 0;
    }
    .topbar-title { font-size: 13px; font-weight: 700; color: #f0f6fc; white-space: nowrap; }
    .topbar-sub   { font-size: 10px; color: #6e7681; white-space: nowrap; }

    .topbar-divider { width: 1px; height: 24px; background: #21262d; margin: 0 20px; }

    /* ── 탭 ── */
    .nav-tabs { display: flex; gap: 4px; height: 100%; align-items: center; }

    .nav-tab {
      display: flex; align-items: center; gap: 7px;
      padding: 6px 16px; border-radius: 7px;
      font-size: 12px; font-weight: 600;
      cursor: pointer; border: 1.5px solid transparent;
      background: transparent; color: #8b949e;
      transition: all 0.15s; white-space: nowrap;
    }
    .nav-tab:hover  { background: #1f2937; color: #e6edf3; }
    .nav-tab.active { background: #1f2937; border-color: #3b82f6; color: #60a5fa; }
    .nav-tab-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }

    .topbar-right {
      margin-left: auto;
      display: flex; align-items: center; gap: 10px;
    }
    .env-badge {
      font-size: 10px; font-weight: 700; letter-spacing: 0.5px;
      padding: 3px 9px; border-radius: 4px;
      background: #1a1200; border: 1px solid #d29922; color: #d29922;
    }
    .date-label { font-size: 10px; color: #6e7681; font-family: monospace; }

    /* ── iframe 영역 ── */
    .frame-wrap { flex: 1; position: relative; overflow: hidden; }

    .frame-pane {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      display: none;
    }
    .frame-pane.active { display: block; }

    .frame-pane iframe {
      width: 100%; height: 100%;
      border: none; background: #0d1117;
    }
  </style>
</head>
<body>

<!-- ══ 상단 네비게이션 바 ══ -->
<div class="topbar">

  <div class="topbar-logo">
    <div class="topbar-icon">🤖</div>
    <div>
      <div class="topbar-title">AI Agent 기반 지능형 통합 모니터링 고도화</div>
      <div class="topbar-sub">폐쇄망 환경 · Grafana + Ollama + Prometheus + Loki</div>
    </div>
  </div>

  <div class="topbar-divider"></div>

  <div class="nav-tabs">
    <button class="nav-tab active" onclick="showPane(0)">
      <div class="nav-tab-dot" style="background:#3b82f6;"></div>
      전체 아키텍처
    </button>
    <button class="nav-tab" onclick="showPane(1)">
      <div class="nav-tab-dot" style="background:#a855f7;"></div>
      AI 분석 파이프라인 흐름
    </button>
  </div>

  <div class="topbar-right">
    <span class="env-badge">폐쇄망</span>
    <span class="date-label" id="clock"></span>
  </div>

</div>

<!-- ══ iframe 패널 ══ -->
<div class="frame-wrap">
  <div class="frame-pane active" id="pane-0">
    <iframe src="architecture.html" title="전체 아키텍처"></iframe>
  </div>
  <div class="frame-pane" id="pane-1">
    <iframe src="flow.html" title="AI 분석 파이프라인 흐름"></iframe>
  </div>
</div>

<script>
  function showPane(idx) {
    document.querySelectorAll('.nav-tab').forEach((t, i) => t.classList.toggle('active', i === idx));
    document.querySelectorAll('.frame-pane').forEach((p, i) => p.classList.toggle('active', i === idx));
  }

  function updateClock() {
    const now = new Date();
    const pad = n => String(n).padStart(2, '0');
    document.getElementById('clock').textContent =
      `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}  ${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;
  }
  updateClock();
  setInterval(updateClock, 1000);
</script>

</body>
</html>
