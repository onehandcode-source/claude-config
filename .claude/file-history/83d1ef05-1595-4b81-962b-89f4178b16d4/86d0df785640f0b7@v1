```typescript
import {
    Directive,
    ElementRef,
    HostListener,
    Input,
    OnDestroy,
} from '@angular/core';

@Directive({
    selector: '[appColumnResize]',
})
export class ColumnResizeDirective implements OnDestroy {
    @Input() minWidth = 60;

    private startX = 0;
    private startWidth = 0;
    private resizing = false;

    private readonly onMove = (e: MouseEvent) => {
        if (!this.resizing) return;
        const dx = e.clientX - this.startX;
        const next = Math.max(this.minWidth, this.startWidth + dx);
        this.host.nativeElement.style.width = `${next}px`;
    };

    private readonly onUp = () => {
        this.resizing = false;
        document.removeEventListener('mousemove', this.onMove);
        document.removeEventListener('mouseup', this.onUp);
    };

    constructor(private readonly host: ElementRef<HTMLElement>) {}

    @HostListener('mousedown', ['$event'])
    onDown(e: MouseEvent): void {
        this.startX = e.clientX;
        this.startWidth = this.host.nativeElement.getBoundingClientRect().width;
        this.resizing = true;
        document.addEventListener('mousemove', this.onMove);
        document.addEventListener('mouseup', this.onUp);
    }

    ngOnDestroy(): void {
        document.removeEventListener('mousemove', this.onMove);
        document.removeEventListener('mouseup', this.onUp);
    }
}
