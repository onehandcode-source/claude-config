```typescript
import { expect, test } from '@playwright/test';

const STORAGE_KEY = 'trmdict_token';
const ADMIN_USER = 'admin';
const ADMIN_PASS = 'Admin123!';

test.describe('C2 인증 흐름', () => {
    test.beforeEach(async ({ page }) => {
        await page.goto('/login');
        await page.evaluate((key) => localStorage.removeItem(key), STORAGE_KEY);
    });

    test('1. 로그인 성공 → /home redirect + 헤더에 사용자명 + token 저장', async ({ page }) => {
        await page.goto('/login');
        await page.getByLabel('아이디').fill(ADMIN_USER);
        await page.getByLabel('비밀번호').fill(ADMIN_PASS);
        await page.getByRole('button', { name: '로그인' }).click();

        await expect(page).toHaveURL(/\/home$/);
        await expect(page.locator('.main-layout__user')).toContainText('로컬관리자');

        const token = await page.evaluate((key) => localStorage.getItem(key), STORAGE_KEY);
        expect(token).toBeTruthy();
    });

    test('2. 잘못된 비번 → toast + /login 유지 + token 미저장', async ({ page }) => {
        await page.goto('/login');
        await page.getByLabel('아이디').fill(ADMIN_USER);
        await page.getByLabel('비밀번호').fill('WrongPass!');
        await page.getByRole('button', { name: '로그인' }).click();

        await expect(page.locator('snack-bar-container')).toBeVisible();
        await expect(page).toHaveURL(/\/login/);

        const token = await page.evaluate((key) => localStorage.getItem(key), STORAGE_KEY);
        expect(token).toBeNull();
    });

    test('3. 위조 token으로 /home 접근 → 첫 API 호출 시 401 → /login redirect + token clear', async ({
        page,
    }) => {
        await page.goto('/login');
        await page.evaluate(
            ([key, val]) => localStorage.setItem(key, val),
            [STORAGE_KEY, 'forged.token.xyz']
        );

        await page.goto('/home');
        // /api/v1/auth/me에서 401 응답 → ErrorInterceptor가 logout + redirect
        await expect(page).toHaveURL(/\/login\?returnUrl=%2Fhome/);

        const token = await page.evaluate((key) => localStorage.getItem(key), STORAGE_KEY);
        expect(token).toBeNull();
    });

    test('4. token 없이 /home 직접 진입 → AuthGuard 차단 → /login?returnUrl=%2Fhome', async ({
        page,
    }) => {
        await page.goto('/login');
        await page.evaluate((key) => localStorage.removeItem(key), STORAGE_KEY);

        await page.goto('/home');
        await expect(page).toHaveURL(/\/login\?returnUrl=%2Fhome/);
    });
});
```

> 시나리오 3은 위조 token 주입 후 `/home` 진입 시 lazy-loaded HomeModule이 발동되며 동시에 `app.component`의 `auth.loadMe()`가 호출됨 → backend가 위조 token으로 401 → ErrorInterceptor가 logout + navigate. 위조 token 자체로 `AuthGuard`는 통과해버린다는 점이 핵심(`isAuthenticated`는 단순 token 존재 여부).

