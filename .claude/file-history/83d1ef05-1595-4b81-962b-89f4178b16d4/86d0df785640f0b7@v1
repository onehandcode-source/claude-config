import { Observable } from 'rxjs';
import { AuthService } from '../../core/services/auth.service';
import { User } from '../../core/models/user.model';
import { MENU_ITEMS, SidenavMenuItem } from './menu-items';

@Component({
    selector: 'app-main-layout',
    templateUrl: './main-layout.component.html',
    styleUrls: ['./main-layout.component.scss'],
})
export class MainLayoutComponent {
    readonly me$: Observable<User | null>;
    readonly menuItems: SidenavMenuItem[] = MENU_ITEMS;

    constructor(private readonly auth: AuthService, private readonly router: Router) {
        this.me$ = this.auth.me$;
    }

    isVisible(item: SidenavMenuItem, role: 'USER' | 'ADMIN' | undefined): boolean {
        if (!item.requiredRole) {
            return true;
        }
        return item.requiredRole === role;
    }

    logout(): void {
        this.auth.logout();
        this.router.navigate(['/login']);
    }
}
