package com.devwogns.trmdict.module.forbidden.service;

import com.devwogns.trmdict.common.exception.BusinessException;
import com.devwogns.trmdict.common.exception.ErrorCode;
import com.devwogns.trmdict.common.response.PageResponse;
import com.devwogns.trmdict.module.forbidden.dto.ForbiddenSearchDto;
import com.devwogns.trmdict.module.forbidden.entity.ForbiddenEntity;
import com.devwogns.trmdict.module.forbidden.repository.ForbiddenRepository;
import com.devwogns.trmdict.module.forbidden.vo.ForbiddenDtlVo;
import com.devwogns.trmdict.module.forbidden.vo.ForbiddenListVo;
import lombok.RequiredArgsConstructor;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.PageRequest;
import org.springframework.data.domain.Pageable;
import org.springframework.data.domain.Sort;
import org.springframework.data.jpa.domain.Specification;
import org.springframework.stereotype.Service;
import org.springframework.util.StringUtils;

import java.util.Collections;
import java.util.HashMap;
import java.util.HashSet;
import java.util.List;
import java.util.Locale;
import java.util.Map;
import java.util.Set;
import java.util.stream.Collectors;

@Service
@RequiredArgsConstructor
public class ForbiddenService {
    private static final char LIKE_ESCAPE_CHAR = '\\';

    private static final Map<String, String> SORTABLE_COLUMNS;
    private static final Set<String> SORTABLE_DIRS;

    private static final String DEFAULT_SORT_BY = "reg_dt";
    private static final String DEFAULT_SORT_DIR = "desc";

    private static final int DEFAULT_PAGE = 1;
    private static final int DEFAULT_SIZE = 20;
    private static final int MAX_SIZE = 100;

    static {
        Map<String, String> sortableColumns = new HashMap<>();
        sortableColumns.put("phwrd_nm", "phwrdNm");
        sortableColumns.put("use_yn", "useYn");
        sortableColumns.put("enct_cycl", "enctCycl");
        sortableColumns.put("mdfcn_dt", "mdfcnDt");
        sortableColumns.put("reg_dt", "regDt");
        SORTABLE_COLUMNS = Collections.unmodifiableMap(sortableColumns);

        Set<String> sortableDirs = new HashSet<>();
        sortableDirs.add("asc");
        sortableDirs.add("desc");
        SORTABLE_DIRS = Collections.unmodifiableSet(sortableDirs);
    }

    private final ForbiddenRepository repository;

    public PageResponse<ForbiddenListVo> search(ForbiddenSearchDto criteria) {
        if (criteria == null) {
            criteria = new ForbiddenSearchDto();
        }
        normalizeAndValidate(criteria);

        Page<ForbiddenEntity> page = repository.findAll(buildSpecification(criteria), buildPageable(criteria));
        List<ForbiddenListVo> items = page.getContent().stream()
                .map(ForbiddenListVo::fromEntity)
                .collect(Collectors.toList());

        return PageResponse.of(items, criteria.getPage(), criteria.getSize(), page.getTotalElements());
    }

    public ForbiddenDtlVo findById(Long id) {
        if (id == null) {
            throw new BusinessException(ErrorCode.COMMON_0001);
        }
        ForbiddenEntity entity = repository.findById(id)
                .orElseThrow(() -> new BusinessException(ErrorCode.FORBIDDEN_5001));
        return ForbiddenDtlVo.fromEntity(entity);
    }

    private void normalizeAndValidate(ForbiddenSearchDto criteria) {
        if (criteria.getPage() == null || criteria.getPage() < 1) {
            criteria.setPage(DEFAULT_PAGE);
        }
        if (criteria.getSize() == null || criteria.getSize() < 1) {
            criteria.setSize(DEFAULT_SIZE);
        }
        if (criteria.getSize() > MAX_SIZE) {
            throw new BusinessException(ErrorCode.COMMON_0001);
        }
        normalizeUseYn(criteria);

        if (!StringUtils.hasText(criteria.getSortBy())) {
            criteria.setSortBy(DEFAULT_SORT_BY);
        } else {
            String normalizedSortBy = criteria.getSortBy().toLowerCase(Locale.ROOT);
            if (!SORTABLE_COLUMNS.containsKey(normalizedSortBy)) {
                throw new BusinessException(ErrorCode.COMMON_0001);
            }
            criteria.setSortBy(normalizedSortBy);
        }

        if (!StringUtils.hasText(criteria.getSortDir())) {
            criteria.setSortDir(DEFAULT_SORT_DIR);
        } else {
            String normalizedSortDir = criteria.getSortDir().toLowerCase(Locale.ROOT);
            if (!SORTABLE_DIRS.contains(normalizedSortDir)) {
                throw new BusinessException(ErrorCode.COMMON_0001);
            }
            criteria.setSortDir(normalizedSortDir);
        }
    }

    private void normalizeUseYn(ForbiddenSearchDto criteria) {
        if (!StringUtils.hasText(criteria.getUseYn())) {
            return;
        }

        String normalizedUseYn = criteria.getUseYn().trim().toUpperCase(Locale.ROOT);
        if (!"Y".equals(normalizedUseYn) && !"N".equals(normalizedUseYn)) {
            throw new BusinessException(ErrorCode.COMMON_0001);
        }
        criteria.setUseYn(normalizedUseYn);
    }

    private Pageable buildPageable(ForbiddenSearchDto criteria) {
        Sort.Direction direction = Sort.Direction.fromString(criteria.getSortDir());
        return PageRequest.of(criteria.getPage() - 1, criteria.getSize(), Sort.by(direction, SORTABLE_COLUMNS.get(criteria.getSortBy())));
    }

    private Specification<ForbiddenEntity> buildSpecification(ForbiddenSearchDto criteria) {
        Specification<ForbiddenEntity> specification = Specification.where(null);
        specification = specification.and(contains("phwrdNm", criteria.getPhwrdNm()));
        specification = specification.and(equalsTo("useYn", criteria.getUseYn()));
        return specification;
    }

    private Specification<ForbiddenEntity> contains(String property, String value) {
        if (!StringUtils.hasText(value)) {
            return null;
        }
        String escapedValue = escapeLikePattern(value);
        return (root, query, cb) -> cb.like(root.get(property).as(String.class), "%" + escapedValue + "%", LIKE_ESCAPE_CHAR);
    }

    private Specification<ForbiddenEntity> equalsTo(String property, String value) {
        if (!StringUtils.hasText(value)) {
            return null;
        }
        return (root, query, cb) -> cb.equal(root.get(property), value);
    }

    private String escapeLikePattern(String value) {
        return value
                .replace("\\", "\\\\")
                .replace("%", "\\%")
                .replace("_", "\\_");
    }
}
