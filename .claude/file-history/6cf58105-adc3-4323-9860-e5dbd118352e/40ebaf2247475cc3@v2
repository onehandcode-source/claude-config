import { useState } from 'react';
import { CardList } from '@/shared/components/CardList/CardList';
import { SearchForm } from '@/shared/components/SearchForm/SearchForm';
import { Input } from '@/shared/components/ui/input';
import { emptyToNull } from '@/shared/query/queryHelpers';
import { useListPage } from '@/shared/hooks/useListPage';
import { DomainDetailDialog } from './DomainDetailDialog';

const dataTypeOptions = Object.freeze(['', 'VARCHAR', 'CHAR', 'NUMERIC', 'DATETIME']);

const initialFilters = Object.freeze({
    stdDmnNm: '',
    stdDmnGroupNm: '',
    stdDmnClsfNm: '',
    dataTypeNm: '',
    useYn: '',
});

const Badge = ({ children, color, bg }) => (
    <span
        style={{
            fontSize: '11px',
            fontWeight: 600,
            padding: '2px 8px',
            borderRadius: '100px',
            color,
            background: bg,
            whiteSpace: 'nowrap',
        }}
    >
        {children}
    </span>
);

const DomainCard = ({ domain, onClick }) => (
    <button
        type='button'
        onClick={() => onClick(domain)}
        style={{
            width: '100%',
            textAlign: 'left',
            background: 'hsl(var(--card))',
            border: '1px solid hsl(var(--border))',
            borderRadius: '10px',
            padding: '14px 16px',
            cursor: 'pointer',
            transition: 'border-color 0.12s, box-shadow 0.12s',
        }}
        onMouseEnter={(e) => {
            e.currentTarget.style.borderColor = 'hsl(var(--primary))';
            e.currentTarget.style.boxShadow = '0 2px 8px rgba(37,99,235,0.08)';
        }}
        onMouseLeave={(e) => {
            e.currentTarget.style.borderColor = 'hsl(var(--border))';
            e.currentTarget.style.boxShadow = 'none';
        }}
    >
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', gap: '12px' }}>
            <div style={{ minWidth: 0, flex: 1 }}>
                <div style={{ marginBottom: '4px' }}>
                    <span style={{ fontSize: '15px', fontWeight: 600, color: 'hsl(var(--foreground))' }}>
                        {domain.stdDmnNm}
                    </span>
                </div>
                <div
                    style={{
                        fontSize: '13px',
                        color: 'hsl(var(--muted-foreground))',
                        display: 'flex',
                        gap: '16px',
                        flexWrap: 'wrap',
                    }}
                >
                    {domain.stdDmnGroupNm && <span>{domain.stdDmnGroupNm}</span>}
                    {domain.stdDmnClsfNm && <span>{domain.stdDmnClsfNm}</span>}
                    {domain.dataLen && (
                        <span>
                            {domain.dataTypeNm}({domain.dataLen}
                            {domain.unitNm ? ` ${domain.unitNm}` : ''})
                        </span>
                    )}
                    {domain.enctCycl && <span>제정 {domain.enctCycl}차</span>}
                </div>
            </div>
            <div style={{ display: 'flex', gap: '6px', flexShrink: 0 }}>
                {domain.dataTypeNm && !domain.dataLen && (
                    <Badge color='#2563eb' bg='#eff6ff'>
                        {domain.dataTypeNm}
                    </Badge>
                )}
                <Badge
                    color={domain.useYn === 'Y' ? '#059669' : '#6b7280'}
                    bg={domain.useYn === 'Y' ? '#d1fae5' : '#f3f4f6'}
                >
                    {domain.useYn === 'Y' ? '사용' : '미사용'}
                </Badge>
            </div>
        </div>
    </button>
);

export const DomainListPage = () => {
    const [filters, setFilters] = useState(initialFilters);
    const { request, setRequest, setSelectedId, isDetailOpen, pageQuery, detailQuery } = useListPage({
        listQueryKey: 'domain-list',
        listUrl: '/domains/search',
        detailQueryKey: 'domain-detail',
        detailUrl: '/domains',
        initialRequest: { page: 1, size: 20 },
    });

    return (
        <div className='space-y-4'>
            <h1 style={{ fontSize: '18px', fontWeight: 700, color: 'hsl(var(--foreground))', margin: 0 }}>
                도메인 목록
            </h1>

            <SearchForm
                onSubmit={() => {
                    setRequest({
                        page: 1,
                        size: request.size,
                        stdDmnNm: emptyToNull(filters.stdDmnNm),
                        stdDmnGroupNm: emptyToNull(filters.stdDmnGroupNm),
                        stdDmnClsfNm: emptyToNull(filters.stdDmnClsfNm),
                        dataTypeNm: emptyToNull(filters.dataTypeNm),
                        useYn: emptyToNull(filters.useYn),
                    });
                }}
                onReset={() => {
                    setFilters(initialFilters);
                    setRequest({ page: 1, size: request.size });
                }}
            >
                <div className='grid w-full gap-3 md:grid-cols-2 xl:grid-cols-5'>
                    <div className='space-y-2'>
                        <label className='text-sm font-medium text-foreground' htmlFor='stdDmnNm'>
                            도메인명
                        </label>
                        <Input
                            id='stdDmnNm'
                            value={filters.stdDmnNm}
                            onChange={(event) =>
                                setFilters((current) => ({ ...current, stdDmnNm: event.target.value }))
                            }
                        />
                    </div>
                    <div className='space-y-2'>
                        <label className='text-sm font-medium text-foreground' htmlFor='stdDmnGroupNm'>
                            그룹명
                        </label>
                        <Input
                            id='stdDmnGroupNm'
                            value={filters.stdDmnGroupNm}
                            onChange={(event) =>
                                setFilters((current) => ({ ...current, stdDmnGroupNm: event.target.value }))
                            }
                        />
                    </div>
                    <div className='space-y-2'>
                        <label className='text-sm font-medium text-foreground' htmlFor='stdDmnClsfNm'>
                            분류명
                        </label>
                        <Input
                            id='stdDmnClsfNm'
                            value={filters.stdDmnClsfNm}
                            onChange={(event) =>
                                setFilters((current) => ({ ...current, stdDmnClsfNm: event.target.value }))
                            }
                        />
                    </div>
                    <div className='space-y-2'>
                        <label className='text-sm font-medium text-foreground' htmlFor='dataTypeNm'>
                            데이터타입
                        </label>
                        <select
                            id='dataTypeNm'
                            className='flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm text-foreground'
                            value={filters.dataTypeNm}
                            onChange={(event) =>
                                setFilters((current) => ({ ...current, dataTypeNm: event.target.value }))
                            }
                        >
                            {dataTypeOptions.map((option) => (
                                <option key={option || 'all'} value={option}>
                                    {option || '전체'}
                                </option>
                            ))}
                        </select>
                    </div>
                    <div className='space-y-2'>
                        <label className='text-sm font-medium text-foreground' htmlFor='useYn'>
                            사용여부
                        </label>
                        <select
                            id='useYn'
                            className='flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm text-foreground'
                            value={filters.useYn}
                            onChange={(event) =>
                                setFilters((current) => ({ ...current, useYn: event.target.value }))
                            }
                        >
                            <option value=''>전체</option>
                            <option value='Y'>사용</option>
                            <option value='N'>미사용</option>
                        </select>
                    </div>
                </div>
            </SearchForm>

            <CardList
                pageData={pageQuery.data ?? null}
                pageSizeOptions={[10, 20, 50, 100]}
                onPageChange={({ page, size }) => setRequest((current) => ({ ...current, page, size }))}
                renderItem={(domain) => (
                    <DomainCard key={domain.id} domain={domain} onClick={(d) => setSelectedId(d.id)} />
                )}
            />

            <DomainDetailDialog
                domain={detailQuery.data ?? null}
                open={isDetailOpen}
                onOpenChange={(open) => {
                    if (!open) setSelectedId(null);
                }}
            />
        </div>
    );
};
