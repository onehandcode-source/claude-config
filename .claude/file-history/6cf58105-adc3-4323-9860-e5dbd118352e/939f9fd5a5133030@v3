import { useState } from 'react';
import { Link, Outlet, useMatches, useNavigate } from 'react-router-dom';
import { logout as logoutApi } from '@/features/auth/authApi';
import { useAuthStore } from '@/store/useAuthStore';
import { LayoutHeader } from './components/LayoutHeader';
import { SidebarSurface } from './components/SidebarSurface';

export const MainLayout = () => {
    const navigate = useNavigate();
    const user = useAuthStore((state) => state.user);
    const logout = useAuthStore((state) => state.logout);
    const [mobileMenuOpen, setMobileMenuOpen] = useState(false);

    const handleLogout = async () => {
        try {
            await logoutApi();
        } finally {
            logout();
            navigate('/login');
        }
    };

    const matches = useMatches();
    const crumbs = matches
        .filter((m) => m.handle?.breadcrumb)
        .map((m) => ({
            label: typeof m.handle.breadcrumb === 'function' ? m.handle.breadcrumb(m) : m.handle.breadcrumb,
            to: m.pathname,
        }));

    return (
        <div className='min-h-screen bg-background text-foreground'>
            <LayoutHeader
                mobileMenuOpen={mobileMenuOpen}
                onMobileMenuOpenChange={setMobileMenuOpen}
                onLogout={handleLogout}
                user={user}
            />
            <div
                className='flex'
                style={{ marginTop: 'var(--nav-h)', minHeight: 'calc(100vh - var(--nav-h))' }}
            >
                <aside
                    className='hidden lg:flex flex-col flex-shrink-0 bg-card border-r border-border'
                    style={{
                        width: 'var(--sidebar-w)',
                        position: 'sticky',
                        top: 'var(--nav-h)',
                        height: 'calc(100vh - var(--nav-h))',
                        overflowY: 'auto',
                    }}
                >
                    <SidebarSurface user={user} />
                </aside>
                <main className='flex-1 min-w-0' style={{ padding: '24px 28px' }}>
                    {crumbs.length > 0 && (
                        <nav
                            aria-label='breadcrumb'
                            style={{
                                display: 'flex',
                                alignItems: 'center',
                                gap: '6px',
                                marginBottom: '16px',
                                fontSize: '13px',
                            }}
                        >
                            {crumbs.map((crumb, i) => (
                                <span key={crumb.to} style={{ display: 'flex', alignItems: 'center', gap: '6px' }}>
                                    {i > 0 && (
                                        <span style={{ color: 'hsl(var(--muted-foreground))', userSelect: 'none' }}>
                                            /
                                        </span>
                                    )}
                                    {i < crumbs.length - 1 ? (
                                        <Link
                                            to={crumb.to}
                                            style={{
                                                color: 'hsl(var(--muted-foreground))',
                                                textDecoration: 'none',
                                            }}
                                        >
                                            {crumb.label}
                                        </Link>
                                    ) : (
                                        <span
                                            aria-current='page'
                                            style={{ color: 'hsl(var(--foreground))', fontWeight: 500 }}
                                        >
                                            {crumb.label}
                                        </span>
                                    )}
                                </span>
                            ))}
                        </nav>
                    )}
                    <Outlet />
                </main>
            </div>
        </div>
    );
};
