import { useState } from 'react';
import { CardList } from '@/shared/components/CardList/CardList';
import { SearchForm } from '@/shared/components/SearchForm/SearchForm';
import { Input } from '@/shared/components/ui/input';
import { emptyToNull } from '@/shared/query/queryHelpers';
import { useListPage } from '@/shared/hooks/useListPage';
import { ForbiddenDetailDialog } from './ForbiddenDetailDialog';

const filtersInitialState = Object.freeze({
    phwrdNm: '',
    useYn: '',
});

const Badge = ({ children, color, bg }) => (
    <span
        style={{
            fontSize: '11px',
            fontWeight: 600,
            padding: '2px 8px',
            borderRadius: '100px',
            color,
            background: bg,
            whiteSpace: 'nowrap',
        }}
    >
        {children}
    </span>
);

const ForbiddenCard = ({ forbidden, onClick }) => (
    <button
        type='button'
        onClick={() => onClick(forbidden)}
        style={{
            width: '100%',
            textAlign: 'left',
            background: 'hsl(var(--card))',
            border: '1px solid hsl(var(--border))',
            borderRadius: '10px',
            padding: '14px 16px',
            cursor: 'pointer',
            transition: 'border-color 0.12s, box-shadow 0.12s',
        }}
        onMouseEnter={(e) => {
            e.currentTarget.style.borderColor = '#ef4444';
            e.currentTarget.style.boxShadow = '0 2px 8px rgba(239,68,68,0.08)';
        }}
        onMouseLeave={(e) => {
            e.currentTarget.style.borderColor = 'hsl(var(--border))';
            e.currentTarget.style.boxShadow = 'none';
        }}
    >
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', gap: '12px' }}>
            <div style={{ minWidth: 0, flex: 1 }}>
                <div style={{ marginBottom: '4px' }}>
                    <span style={{ fontSize: '15px', fontWeight: 600, color: 'hsl(var(--foreground))' }}>
                        {forbidden.phwrdNm}
                    </span>
                </div>
                <div
                    style={{
                        fontSize: '13px',
                        color: 'hsl(var(--muted-foreground))',
                        display: 'flex',
                        gap: '16px',
                        flexWrap: 'wrap',
                    }}
                >
                    {forbidden.enctCycl && <span>제정 {forbidden.enctCycl}차</span>}
                    {forbidden.rmrkCn && (
                        <span
                            style={{
                                overflow: 'hidden',
                                textOverflow: 'ellipsis',
                                whiteSpace: 'nowrap',
                                maxWidth: '300px',
                            }}
                        >
                            {forbidden.rmrkCn}
                        </span>
                    )}
                </div>
            </div>
            <div style={{ flexShrink: 0 }}>
                <Badge
                    color={forbidden.useYn === 'Y' ? '#059669' : '#6b7280'}
                    bg={forbidden.useYn === 'Y' ? '#d1fae5' : '#f3f4f6'}
                >
                    {forbidden.useYn === 'Y' ? '사용' : '미사용'}
                </Badge>
            </div>
        </div>
    </button>
);

export const ForbiddenListPage = () => {
    const [filters, setFilters] = useState(filtersInitialState);
    const { request, setRequest, setSelectedId, isDetailOpen, pageQuery, detailQuery } = useListPage({
        listQueryKey: 'forbidden-list',
        listUrl: '/forbiddens/search',
        detailQueryKey: 'forbidden-detail',
        detailUrl: '/forbiddens',
        initialRequest: { page: 1, size: 20 },
    });

    return (
        <div className='space-y-4'>
            <h1 style={{ fontSize: '18px', fontWeight: 700, color: 'hsl(var(--foreground))', margin: 0 }}>
                금칙어 목록
            </h1>

            <SearchForm
                onSubmit={() => {
                    setRequest({
                        page: 1,
                        size: request.size,
                        phwrdNm: emptyToNull(filters.phwrdNm),
                        useYn: emptyToNull(filters.useYn),
                    });
                }}
                onReset={() => {
                    setFilters(filtersInitialState);
                    setRequest({ page: 1, size: request.size });
                }}
            >
                <div className='grid w-full gap-3 md:grid-cols-2'>
                    <div className='space-y-2'>
                        <label className='text-sm font-medium text-foreground' htmlFor='phwrdNm'>
                            금칙어명
                        </label>
                        <Input
                            id='phwrdNm'
                            value={filters.phwrdNm}
                            onChange={(event) =>
                                setFilters((current) => ({ ...current, phwrdNm: event.target.value }))
                            }
                        />
                    </div>
                    <div className='space-y-2'>
                        <label className='text-sm font-medium text-foreground' htmlFor='useYn'>
                            사용여부
                        </label>
                        <select
                            id='useYn'
                            className='flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm text-foreground'
                            value={filters.useYn}
                            onChange={(event) =>
                                setFilters((current) => ({ ...current, useYn: event.target.value }))
                            }
                        >
                            <option value=''>전체</option>
                            <option value='Y'>사용</option>
                            <option value='N'>미사용</option>
                        </select>
                    </div>
                </div>
            </SearchForm>

            <CardList
                pageData={pageQuery.data ?? null}
                pageSizeOptions={[10, 20, 50, 100]}
                onPageChange={({ page, size }) => setRequest((current) => ({ ...current, page, size }))}
                renderItem={(forbidden) => (
                    <ForbiddenCard
                        key={forbidden.id}
                        forbidden={forbidden}
                        onClick={(f) => setSelectedId(f.id)}
                    />
                )}
            />

            <ForbiddenDetailDialog
                forbidden={detailQuery.data ?? null}
                open={isDetailOpen}
                onOpenChange={(open) => {
                    if (!open) setSelectedId(null);
                }}
            />
        </div>
    );
};
