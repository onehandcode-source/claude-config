@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
    :root {
        /* Layout tokens */
        --nav-h: 52px;
        --sidebar-w: 220px;

        /* Color tokens — TermBase palette */
        --background: 220 17% 96%;          /* #f4f6f9 */
        --foreground: 225 40% 11%;          /* #111827 */
        --card: 0 0% 100%;                  /* #ffffff */
        --card-foreground: 218 22% 26%;     /* #374151 */
        --popover: 0 0% 100%;
        --popover-foreground: 225 40% 11%;
        --primary: 217 91% 53%;             /* #2563eb */
        --primary-foreground: 0 0% 100%;
        --secondary: 220 17% 96%;
        --secondary-foreground: 218 22% 26%;
        --muted: 220 17% 96%;
        --muted-foreground: 218 11% 47%;    /* #6b7280 */
        --accent: 214 100% 97%;             /* #eff6ff */
        --accent-foreground: 217 91% 45%;
        --destructive: 0 84% 60%;
        --destructive-foreground: 0 0% 100%;
        --border: 220 13% 91%;              /* #e5e7eb */
        --input: 220 13% 91%;
        --ring: 217 91% 53%;
        --radius: 0.375rem;

        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        font-size: 14px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
    }

    .dark {
        --background: 225 40% 8%;
        --foreground: 210 40% 98%;
        --card: 225 35% 12%;
        --card-foreground: 210 40% 96%;
        --popover: 225 35% 12%;
        --popover-foreground: 210 40% 98%;
        --primary: 217 91% 60%;
        --primary-foreground: 0 0% 100%;
        --secondary: 225 30% 18%;
        --secondary-foreground: 210 40% 98%;
        --muted: 225 30% 18%;
        --muted-foreground: 215 20% 65%;
        --accent: 217 50% 20%;
        --accent-foreground: 217 91% 70%;
        --destructive: 0 63% 31%;
        --destructive-foreground: 210 40% 98%;
        --border: 225 25% 22%;
        --input: 225 25% 22%;
        --ring: 217 91% 60%;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        border-color: hsl(var(--border));
    }

    body {
        margin: 0;
        background-color: hsl(var(--background));
        color: hsl(var(--foreground));
    }

    button, input, select {
        font: inherit;
    }
}
