import { TiberoConfig } from './types';

export interface DbQueryResult {
  rows: any[];
  rowCount: number;
  columns: string[];
}

export async function executeDbQuery(
  config: TiberoConfig,
  query: string
): Promise<DbQueryResult> {
  const oracledb = await import('oracledb');

  let connection: any;
  try {
    connection = await oracledb.default.getConnection({
      user: config.username,
      password: config.password,
      connectString: `${config.host}:${config.port}/${config.serviceName}`,
    });

    const result = await connection.execute(query, [], {
      outFormat: oracledb.default.OUT_FORMAT_OBJECT,
      maxRows: 1000,
    });

    const rows = result.rows ?? [];
    const columns = result.metaData?.map((m: any) => m.name) ?? [];

    return { rows, rowCount: rows.length, columns };
  } finally {
    if (connection) await connection.close();
  }
}
```

