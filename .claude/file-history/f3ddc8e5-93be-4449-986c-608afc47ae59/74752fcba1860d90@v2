import fs from 'fs';
import path from 'path';
import { Scenario } from './types';

const SCENARIOS_DIR = path.join(process.cwd(), 'data', 'scenarios');

function ensureDir() {
  if (!fs.existsSync(SCENARIOS_DIR)) fs.mkdirSync(SCENARIOS_DIR, { recursive: true });
}

function filePath(id: string) {
  return path.join(SCENARIOS_DIR, `${id}.json`);
}

export function listScenarios(): Scenario[] {
  ensureDir();
  return fs
    .readdirSync(SCENARIOS_DIR)
    .filter((f) => f.endsWith('.json'))
    .map((f) => JSON.parse(fs.readFileSync(path.join(SCENARIOS_DIR, f), 'utf-8')) as Scenario);
}

export function getScenario(id: string): Scenario | null {
  const fp = filePath(id);
  if (!fs.existsSync(fp)) return null;
  return JSON.parse(fs.readFileSync(fp, 'utf-8')) as Scenario;
}

export function saveScenario(scenario: Scenario): void {
  ensureDir();
  fs.writeFileSync(filePath(scenario.id), JSON.stringify(scenario, null, 2), 'utf-8');
}

export function deleteScenario(id: string): boolean {
  const fp = filePath(id);
  if (!fs.existsSync(fp)) return false;
  fs.unlinkSync(fp);
  return true;
}
