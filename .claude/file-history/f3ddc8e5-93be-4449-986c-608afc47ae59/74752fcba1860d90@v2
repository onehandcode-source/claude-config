'use client';

import { useEffect, useState } from 'react';
import { Scenario, ScenarioResult, ComparisonReport } from '@/lib/types';
import { RunView } from '@/components/RunView';
import { CompareView } from '@/components/CompareView';
import { Button } from '@/components/ui/button';
import Link from 'next/link';

type Mode = 'idle' | 'running' | 'result' | 'compare';

export default function RunPage({ params }: { params: { id: string } }) {
  const [scenario, setScenario] = useState<Scenario | null>(null);
  const [mode, setMode] = useState<Mode>('idle');
  const [result, setResult] = useState<ScenarioResult | null>(null);
  const [report, setReport] = useState<ComparisonReport | null>(null);
  const [snapshots, setSnapshots] = useState<string[]>([]);
  const [error, setError] = useState<string | null>(null);

  useEffect(() => {
    fetch(`/api/scenarios/${params.id}`).then((r) => r.json()).then((j) => j.success && setScenario(j.data));
    loadSnapshots();
  }, [params.id]);

  async function loadSnapshots() {
    const res = await fetch(`/api/scenarios/${params.id}/snapshots`);
    const j = await res.json();
    if (j.success) setSnapshots(j.data);
  }

  async function handleSaveSnapshot() {
    setMode('running');
    setError(null);
    try {
      const runRes = await fetch(`/api/scenarios/${params.id}/run`, { method: 'POST' });
      const runJson = await runRes.json();
      if (!runJson.success) throw new Error(runJson.error);

      const snapRes = await fetch(`/api/scenarios/${params.id}/snapshot`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(runJson.data),
      });
      const snapJson = await snapRes.json();
      if (!snapJson.success) throw new Error(snapJson.error);

      setResult(runJson.data);
      setMode('result');
      loadSnapshots();
    } catch (e) {
      setError(String(e));
      setMode('idle');
    }
  }

  async function handleCompare() {
    setMode('running');
    setError(null);
    try {
      const res = await fetch(`/api/scenarios/${params.id}/compare`, { method: 'POST' });
      const json = await res.json();
      if (!json.success) throw new Error(json.error);
      setResult(json.data.current);
      setReport(json.data.report);
      setMode('compare');
    } catch (e) {
      setError(String(e));
      setMode('idle');
    }
  }

  if (!scenario) return <div className="p-8 text-muted-foreground">로딩 중...</div>;

  return (
    <main className="container mx-auto py-8 px-4 max-w-3xl">
      <div className="flex items-center justify-between mb-6">
        <h1 className="text-2xl font-bold">{scenario.name}</h1>
        <Link href="/"><Button variant="outline">목록으로</Button></Link>
      </div>

      <div className="flex gap-3 mb-4">
        <Button onClick={handleSaveSnapshot} disabled={mode === 'running'}>
          {mode === 'running' ? '실행 중...' : 'AS-IS로 저장'}
        </Button>
        <Button variant="outline" onClick={handleCompare}
          disabled={mode === 'running' || snapshots.length === 0}>
          현재와 비교
        </Button>
      </div>

      {snapshots.length > 0 && (
        <p className="text-sm text-muted-foreground mb-4">
          저장된 스냅샷 {snapshots.length}개 — 최신: {snapshots[0]}
        </p>
      )}

      {error && (
        <div className="bg-red-50 border border-red-200 rounded p-3 text-red-700 mb-4 text-sm">{error}</div>
      )}

      {mode === 'result' && result && <RunView result={result} />}
      {mode === 'compare' && report && result && (
        <div className="space-y-6">
          <CompareView report={report} />
          <details className="border rounded p-3">
            <summary className="cursor-pointer text-sm text-muted-foreground">현재 실행 결과 상세 보기</summary>
            <div className="mt-3"><RunView result={result} /></div>
          </details>
        </div>
      )}
    </main>
  );
}
```

**Step 4: 전체 흐름 수동 테스트**

1. `npm run dev`
2. `/scenarios/new` → 시나리오 + 테스트케이스 + Step 추가 저장
3. `/scenarios/:id/run` → [AS-IS로 저장] 클릭
4. `data/snapshots/{id}/latest.json` 파일 생성 확인
5. [현재와 비교] 클릭 → 비교 결과 표시 확인

