import { Scenario, TestCase, TestCaseResult, ScenarioResult, TiberoConfig } from './types';
import { PlaywrightExecutor } from './playwright-executor';

async function runTestCase(testCase: TestCase, scenarioDbConfig?: TiberoConfig): Promise<TestCaseResult> {
  const dbConfig = testCase.dbConfig ?? scenarioDbConfig;
  const executor = new PlaywrightExecutor();
  const startTime = Date.now();

  try {
    await executor.initialize();
    const stepResults = await executor.executeSteps(testCase.steps, dbConfig);
    const hasError = stepResults.some((r) => r.status === 'error');

    return {
      testCaseId: testCase.id,
      testCaseName: testCase.name,
      status: hasError ? 'error' : 'passed',
      executionTime: Date.now() - startTime,
      stepResults,
    };
  } catch (error) {
    return {
      testCaseId: testCase.id,
      testCaseName: testCase.name,
      status: 'error',
      executionTime: Date.now() - startTime,
      stepResults: [],
    };
  } finally {
    await executor.close();
  }
}

export async function runScenario(scenario: Scenario): Promise<ScenarioResult> {
  const testCaseResults: TestCaseResult[] = [];

  for (const testCase of scenario.testCases) {
    const result = await runTestCase(testCase, scenario.dbConfig);
    testCaseResults.push(result);
  }

  return {
    scenarioId: scenario.id,
    scenarioName: scenario.name,
    executedAt: new Date().toISOString(),
    testCaseResults,
  };
}
