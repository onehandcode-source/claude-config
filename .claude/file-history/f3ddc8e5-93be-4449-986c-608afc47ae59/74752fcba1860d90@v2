import { NextRequest, NextResponse } from 'next/server';
import { getScenario } from '@/lib/scenario-manager';
import { loadLatestSnapshot } from '@/lib/snapshot-manager';
import { runScenario } from '@/lib/test-runner';
import { compareWithSnapshot } from '@/lib/comparison-engine';

export async function POST(_: NextRequest, { params }: { params: { id: string } }) {
  try {
    const scenario = getScenario(params.id);
    if (!scenario) return NextResponse.json({ success: false, error: 'Not found' }, { status: 404 });

    const snapshot = loadLatestSnapshot(params.id);
    if (!snapshot) return NextResponse.json({ success: false, error: '저장된 AS-IS 스냅샷이 없습니다' }, { status: 400 });

    const current = await runScenario(scenario);
    const report = compareWithSnapshot(snapshot, current);

    return NextResponse.json({ success: true, data: { report, current } });
  } catch (error) {
    return NextResponse.json({ success: false, error: String(error) }, { status: 500 });
  }
}
