import fs from 'fs';
import path from 'path';
import { ScenarioResult } from './types';

const SNAPSHOTS_DIR = path.join(process.cwd(), 'data', 'snapshots');

function scenarioDir(scenarioId: string) {
  return path.join(SNAPSHOTS_DIR, scenarioId);
}

function ensureDir(scenarioId: string) {
  const dir = scenarioDir(scenarioId);
  if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
}

export function saveSnapshot(result: ScenarioResult): string {
  ensureDir(result.scenarioId);
  const dir = scenarioDir(result.scenarioId);
  const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);
  const filename = `${timestamp}.json`;
  const content = JSON.stringify(result, null, 2);
  fs.writeFileSync(path.join(dir, filename), content, 'utf-8');
  fs.writeFileSync(path.join(dir, 'latest.json'), content, 'utf-8');
  return filename;
}

export function loadLatestSnapshot(scenarioId: string): ScenarioResult | null {
  const fp = path.join(scenarioDir(scenarioId), 'latest.json');
  if (!fs.existsSync(fp)) return null;
  return JSON.parse(fs.readFileSync(fp, 'utf-8')) as ScenarioResult;
}

export function listSnapshots(scenarioId: string): string[] {
  const dir = scenarioDir(scenarioId);
  if (!fs.existsSync(dir)) return [];
  return fs
    .readdirSync(dir)
    .filter((f) => f.endsWith('.json') && f !== 'latest.json')
    .sort()
    .reverse();
}
```

