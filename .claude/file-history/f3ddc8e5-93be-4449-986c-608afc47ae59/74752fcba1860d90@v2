```typescript
import {
  ScenarioResult,
  TestCaseResult,
  StepResult,
  ComparisonReport,
  TestCaseDiff,
  StepDiff,
} from './types';

function deepEqual(a: any, b: any): boolean {
  if (a === b) return true;
  if (a == null || b == null) return a === b;
  if (typeof a !== typeof b) return false;
  if (typeof a !== 'object') return a === b;
  const keysA = Object.keys(a);
  const keysB = Object.keys(b);
  if (keysA.length !== keysB.length) return false;
  return keysA.every((k) => deepEqual(a[k], b[k]));
}

function compareTestCase(snapshot: TestCaseResult, current: TestCaseResult): TestCaseDiff {
  const stepDiffs: StepDiff[] = [];
  const len = Math.max(snapshot.stepResults.length, current.stepResults.length);

  for (let i = 0; i < len; i++) {
    const snap: StepResult | undefined = snapshot.stepResults[i];
    const curr: StepResult | undefined = current.stepResults[i];
    const snapshotOutput = snap?.output ?? null;
    const currentOutput = curr?.output ?? null;
    const isDifferent = !deepEqual(snapshotOutput, currentOutput);

    if (isDifferent || snap?.status !== curr?.status) {
      stepDiffs.push({
        stepIndex: i,
        description: snap?.step?.description ?? curr?.step?.description,
        snapshotOutput,
        currentOutput,
        isDifferent,
        severity: snap?.status === 'error' || curr?.status === 'error' ? 'critical' : 'warning',
      });
    }
  }

  return {
    testCaseId: snapshot.testCaseId,
    testCaseName: snapshot.testCaseName,
    status: stepDiffs.length === 0 ? 'identical' : 'different',
    stepDiffs,
  };
}

export function compareWithSnapshot(snapshot: ScenarioResult, current: ScenarioResult): ComparisonReport {
  const testCaseDiffs: TestCaseDiff[] = snapshot.testCaseResults.map((snapTc) => {
    const currTc = current.testCaseResults.find((r) => r.testCaseId === snapTc.testCaseId);
    if (!currTc) {
      return { testCaseId: snapTc.testCaseId, testCaseName: snapTc.testCaseName, status: 'error' as const, stepDiffs: [] };
    }
    return compareTestCase(snapTc, currTc);
  });

  const hasAnyDiff = testCaseDiffs.some((d) => d.status !== 'identical');

  return {
    scenarioId: snapshot.scenarioId,
    snapshotCapturedAt: snapshot.executedAt,
    comparedAt: new Date().toISOString(),
    status: hasAnyDiff ? 'different' : 'identical',
    testCaseDiffs,
  };
}
