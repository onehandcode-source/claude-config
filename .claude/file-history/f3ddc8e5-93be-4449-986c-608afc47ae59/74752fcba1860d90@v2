**Step 1: 파일 전체를 아래 내용으로 교체**

```typescript
import { chromium, Browser, Page } from '@playwright/test';
import { Step, StepResult, TiberoConfig } from './types';
import { executeDbQuery } from './tibero-executor';

export class PlaywrightExecutor {
  private browser: Browser | null = null;

  async initialize() {
    this.browser = await chromium.launch({ headless: true });
  }

  async close() {
    await this.browser?.close();
  }

  async executeSteps(steps: Step[], dbConfig?: TiberoConfig): Promise<StepResult[]> {
    const page = await this.browser!.newPage();
    const results: StepResult[] = [];

    try {
      for (const step of steps) {
        const result = await this.executeStep(step, page, dbConfig);
        results.push(result);
        if (result.status === 'error') break;
      }
    } finally {
      await page.close();
    }

    return results;
  }

  private async executeStep(step: Step, page: Page, dbConfig?: TiberoConfig): Promise<StepResult> {
    try {
      let output: any;

      switch (step.type) {
        case 'navigate':
          await page.goto(step.url, { waitUntil: 'networkidle' });
          output = `Navigated to ${step.url}`;
          break;
        case 'click':
          await page.click(step.selector);
          output = `Clicked: ${step.selector}`;
          break;
        case 'fill':
          await page.fill(step.selector, step.text);
          output = `Filled: ${step.selector}`;
          break;
        case 'select':
          await page.selectOption(step.selector, step.text);
          output = `Selected: ${step.text}`;
          break;
        case 'wait':
          await page.waitForTimeout(step.milliseconds);
          output = `Waited ${step.milliseconds}ms`;
          break;
        case 'screenshot': {
          const buf = await page.screenshot({ fullPage: true });
          output = buf.toString('base64');
          return { step, status: 'passed', output, screenshot: output };
        }
        case 'evaluate':
          output = await page.evaluate((s) => eval(s), step.script);
          break;
        case 'dbQuery': {
          if (!dbConfig) throw new Error('dbQuery step requires dbConfig');
          output = await executeDbQuery(dbConfig, step.query);
          break;
        }
        default:
          throw new Error(`Unknown step type: ${(step as any).type}`);
      }

      return { step, status: 'passed', output };
    } catch (error) {
      return {
        step,
        status: 'error',
        error: error instanceof Error ? error.message : String(error),
      };
    }
  }
}
```

