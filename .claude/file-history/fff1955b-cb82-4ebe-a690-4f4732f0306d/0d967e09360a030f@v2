import { useState, useMemo } from 'react';
import { useQuery } from '@tanstack/react-query';
import { Textarea } from '@/shared/components/ui/textarea';  // shadcn Textarea
import { Card } from '@/shared/components/ui/card';
import { Badge } from '@/shared/components/ui/badge';

// 전체 금칙어 목록 캐싱 (size=9999)
const { data: forbiddenAll = [] } = useQuery({
    queryKey: ['forbidden-all'],
    queryFn: () => axiosInstance.get('/api/v1/forbidden?size=9999').then(r => r.data.data?.items ?? []),
    staleTime: 5 * 60 * 1000,
});

// 입력 텍스트에서 위반 단어 추출
