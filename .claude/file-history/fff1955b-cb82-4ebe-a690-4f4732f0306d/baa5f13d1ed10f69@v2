import { Card } from '@/shared/components/ui/card';

const TREND_DAYS = ['5/21', '5/22', '5/23', '5/24', '5/25', '5/26', '5/27'];
const TREND_SEARCH = [842, 1034, 788, 1156, 943, 1242, 976];
const TREND_MCP = [3120, 3842, 2980, 4102, 3654, 4231, 3842];
const TOP_TERMS = [
    { name: '개인정보처리자', views: 412 },
    { name: '가명처리', views: 387 },
    { name: '주민등록번호', views: 312 },
    { name: '데이터 주체', views: 289 },
