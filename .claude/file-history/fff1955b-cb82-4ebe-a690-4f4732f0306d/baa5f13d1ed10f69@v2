                    <LineChart data={TREND_SEARCH} color={LINE_COLOR} />
                </Card>
                <Card className='p-5 border-[1.5px] border-border-lt rounded-sm bg-bg'>
                    <p className='text-[11px] font-bold tracking-[0.08em] uppercase text-muted-foreground mb-4 m-0'>MCP 호출 수</p>
                    <BarChart data={TREND_MCP} color={BAR_COLOR} />
                </Card>
            </div>

            <div className='grid grid-cols-2 gap-4'>
                <Card className='p-5 border-[1.5px] border-border-lt rounded-sm bg-bg'>
                    <p className='text-[11px] font-bold tracking-[0.08em] uppercase text-muted-foreground mb-4 m-0'>인기 용어 Top 5</p>
                    <div className='space-y-3'>
                        {TOP_TERMS.map((t) => (
                            <div key={t.name} className='flex items-center gap-3'>
                                <span className='text-[12px] min-w-[120px]'>{t.name}</span>
                                <div className='flex-1 h-3 bg-border-lt rounded-sm overflow-hidden'>
