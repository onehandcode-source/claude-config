];
const MOCK_TOOLS = [
    { name: 'search_terms', calls: 2341, p95: 92, errors: 0 },
    { name: 'get_term', calls: 891, p95: 55, errors: 1 },
    { name: 'check_forbidden', calls: 412, p95: 34, errors: 0 },
    { name: 'list_categories', calls: 154, p95: 28, errors: 0 },
    { name: 'get_forbidden_term', calls: 44, p95: 41, errors: 0 },
];

const BAR_COLOR = 'hsl(var(--accent))';
const LINE_COLOR = 'hsl(var(--fg))';

const BarChart = ({ data, color }) => {
    const max = Math.max(...data);
    return (
        <div className='flex items-end gap-1.5 h-[160px]'>
            {data.map((v, i) => (
                <div key={i} className='flex flex-col items-center gap-1 flex-1'>
                    <div
                        className='w-full rounded-sm transition-all'
                        style={{ height: `${(v / max) * 140}px`, background: color }}
                    />
                    <span className='text-[9px] font-mono text-muted-foreground'>{TREND_DAYS[i]}</span>
                </div>
            ))}
        </div>
    );
};

const LineChart = ({ data, color }) => {
    const max = Math.max(...data);
    const min = Math.min(...data);
    const range = max - min || 1;
    const w = 100 / (data.length - 1);
    const points = data.map((v, i) => `${i * w},${100 - ((v - min) / range) * 80 + 10}`).join(' ');
    const areaPoints = `0,100 ${points} ${(data.length - 1) * w},100`;

    return (
        <div className='space-y-1'>
            <svg viewBox='0 0 100 100' preserveAspectRatio='none' className='w-full h-[140px]'>
                <polygon points={areaPoints} fill={color} fillOpacity='0.08' />
                <polyline points={points} fill='none' stroke={color} strokeWidth='2' vectorEffect='non-scaling-stroke' />
                {data.map((v, i) => (
                    <circle key={i} cx={i * w} cy={100 - ((v - min) / range) * 80 + 10} r='3' fill={color} vectorEffect='non-scaling-stroke' />
                ))}
            </svg>
            <div className='flex justify-between'>
                {TREND_DAYS.map((d) => (
                    <span key={d} className='text-[9px] font-mono text-muted-foreground'>{d}</span>
                ))}
            </div>
        </div>
    );
};

const THead = ({ cols }) => (
    <thead>
        <tr className='border-b border-border-lt'>
            {cols.map((h) => <th key={h} className='px-4 py-2.5 text-left text-[11px] font-bold tracking-[0.08em] uppercase text-muted-foreground'>{h}</th>)}
        </tr>
    </thead>
);

