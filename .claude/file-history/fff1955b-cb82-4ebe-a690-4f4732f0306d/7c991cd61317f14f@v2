import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '../ui/select';

const buildPageItems = (currentPage, totalPages) => {
    if (totalPages <= 1) return [];
    if (totalPages <= 7) {
        return Array.from({ length: totalPages }, (_, i) => ({ type: 'page', value: i + 1 }));
    }
    const pages = new Set([1, totalPages, currentPage - 1, currentPage, currentPage + 1]);
    const ordered = [...pages].filter((p) => p >= 1 && p <= totalPages).sort((a, b) => a - b);
    const items = [];
    let last = 0;
    ordered.forEach((p) => {
        if (p - last > 1) items.push({ type: 'ellipsis', key: `e-${last}-${p}` });
        items.push({ type: 'page', value: p });
        last = p;
    });
    return items;
};

export const CardList = ({ pageData, pageSizeOptions = [10, 20, 50, 100], onPageChange, renderItem }) => {
    const items = pageData?.items ?? [];
    const pageItems = buildPageItems(pageData?.page ?? 1, pageData?.totalPages ?? 1);

    return (
        <div>
            <div className='flex items-center justify-between mb-2'>
                <span className='text-[12px] text-muted-foreground font-mono'>
                    총 <strong className='text-fg font-semibold not-italic'>{pageData?.totalElements ?? 0}</strong>건
                </span>
                <Select
                    value={String(pageData?.size ?? pageSizeOptions[0])}
                    onValueChange={(value) => onPageChange?.({ page: 1, size: Number(value) })}
                >
                    <SelectTrigger className='h-7 w-fit px-2 text-[12px] bg-surface border-border-lt'>
                        <SelectValue placeholder='페이지 크기' />
                    </SelectTrigger>
                    <SelectContent>
                        {pageSizeOptions.map((opt) => (
                            <SelectItem key={opt} value={String(opt)}>
                                {opt}개씩 보기
                            </SelectItem>
                        ))}
                    </SelectContent>
                </Select>
            </div>

            {items.length === 0 ? (
                <div className='py-16 text-center text-muted-foreground text-[13px] border border-border-lt border-dashed'>
                    데이터가 없습니다.
                </div>
            ) : (
                <div className='flex flex-col gap-1.5'>
                    {items.map((item) => renderItem(item))}
                </div>
            )}

            {pageItems.length > 0 ? (
                <div className='flex items-center justify-center gap-1 mt-5'>
                    {pageItems.map((pi) =>
                        pi.type === 'ellipsis' ? (
                            <span key={pi.key} className='px-2 text-muted-foreground text-[12px] font-mono select-none'>
                                ···
                            </span>
                        ) : (
                            <button
                                key={pi.value}
                                type='button'
                                className={`min-w-[32px] h-8 px-2 text-[12px] font-medium border transition-colors ${
                                    pi.value === pageData.page
                                        ? 'bg-fg text-bg border-fg'
                                        : 'bg-bg text-fg border-border-lt hover:border-border'
                                }`}
                                aria-current={pi.value === pageData.page ? 'page' : undefined}
                                onClick={() => onPageChange?.({ page: pi.value, size: pageData.size })}
                            >
                                {pi.value}
                            </button>
                        ),
                    )}
                </div>
            ) : null}
        </div>
    );
};
