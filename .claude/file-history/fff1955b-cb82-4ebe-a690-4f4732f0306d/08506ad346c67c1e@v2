@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
    :root {
        /* ── Brand Tokens (HSL numbers) ── */
        --bg: 0 0% 100%;
        --surface: 40 20% 98%;
        --fg: 30 3% 11%;
        --muted: 35 11% 38%;
        --border: 30 3% 11%;
        --border-lt: 40 16% 89%;
        --accent: 14 55% 52%;
        --accent-soft: 14 60% 97%;

        /* ── Layout ── */
        --nav-h: 52px;
        --sidebar-w: 220px;
        --radius: 2px;

        /* ── Typography ── */
        --font-display: 'Iowan Old Style', Charter, Georgia, serif;

        /* ── Shadcn-compatible aliases (inline styles & ui components) ── */
        --background: var(--bg);
        --foreground: var(--fg);
        --card: var(--surface);
        --card-foreground: var(--fg);
        --primary: var(--accent);
        --primary-foreground: 0 0% 100%;
        --secondary: 40 16% 89%;
        --secondary-foreground: 30 3% 11%;
        --muted-foreground: var(--muted);
        --destructive: 0 72% 51%;
        --destructive-foreground: 0 0% 100%;
        --input: var(--border-lt);
        --ring: var(--accent);

        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        font-size: 14px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        background-color: hsl(var(--bg));
        color: hsl(var(--fg));
    }

    .dark {
        --bg: 20 12% 7%;
        --surface: 30 3% 11%;
        --fg: 35 13% 94%;
        --muted: 30 8% 60%;
        --border: 30 5% 24%;
        --border-lt: 30 5% 15%;
        --accent: 14 67% 63%;
        --accent-soft: 14 40% 14%;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        border-color: hsl(var(--border));
    }

    body {
        margin: 0;
        background-color: hsl(var(--bg));
        color: hsl(var(--fg));
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    }

    button, input, select {
        font: inherit;
    }
}
