            className='no-underline h-full'
            onMouseEnter={() => setIsHovered(true)}
            onMouseLeave={() => setIsHovered(false)}
        >
            <div
                className='bg-card border-[1.5px] p-5 h-full flex flex-col gap-3 transition-all'
                style={{
                    borderColor: isHovered ? dotColor : 'hsl(var(--border-lt))',
