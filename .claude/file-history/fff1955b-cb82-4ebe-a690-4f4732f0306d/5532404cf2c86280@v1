import { NavLink } from 'react-router-dom';
import { MENU_ITEMS } from '../menuItems';
import { cn } from '@/lib/utils';

const DOT_COLORS = {
    home: '#9ca3af',
    category: '#8b5cf6',
    word: '#3b82f6',
    forbidden: '#ef4444',
    upload: '#10b981',
};

const NAV_GROUPS = [
    { label: '관리', key: 'manage' },
    { label: '가져오기', key: 'import' },
];

const getVisibleGroups = (user) =>
    NAV_GROUPS.map((group) => {
        const items = MENU_ITEMS.filter(
            (item) => item.group === group.key && (!item.requiredRole || item.requiredRole === user?.role),
        );
        return items.length > 0 ? { ...group, items } : null;
    }).filter(Boolean);

export const SidebarSurface = ({ user, onNavigate }) => {
    const groups = getVisibleGroups(user);
    const initials = user?.name?.charAt(0) ?? 'U';

    return (
        <div className='flex flex-col h-full'>
            <nav className='py-4 flex-1 overflow-y-auto' aria-label='주요 메뉴'>
                {groups.map((group) => (
                    <section key={group.key} className='mb-4'>
                        <p className='px-4 mb-1 text-[11px] font-semibold tracking-wider uppercase text-muted-foreground'>
                            {group.label}
                        </p>
                        <div className='px-2'>
                            {group.items.map((item) => (
                                <NavLink
                                    key={item.route}
                                    to={item.route}
                                    onClick={onNavigate}
                                    className={({ isActive }) =>
                                        cn(
                                            'flex items-center gap-2.5 p-2 px-3 rounded-lg text-[13.5px] no-underline transition-all',
                                            isActive
                                                ? 'font-semibold text-foreground bg-accent'
                                                : 'font-normal text-muted-foreground hover:bg-muted hover:text-foreground',
                                        )
                                    }
                                >
                                    <span
                                        aria-hidden='true'
                                        className='w-2 h-2 rounded-full shrink-0'
                                        style={{ background: DOT_COLORS[item.icon] ?? '#9ca3af' }}
                                    />
                                    {item.label}
                                </NavLink>
                            ))}
                        </div>
                    </section>
                ))}
            </nav>

            <div className='p-3 border-t border-border'>
                <div className='flex items-center gap-2.5 p-2'>
                    <div className='w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center text-[13px] font-bold shrink-0'>
                        {initials}
                    </div>
                    <div className='min-w-0 flex-1'>
                        <p className='m-0 text-[13px] font-medium text-foreground truncate'>
                            {user?.name}
                        </p>
                        <p className='m-0 text-[11px] text-muted-foreground truncate'>
                            {user?.role}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    );
};
