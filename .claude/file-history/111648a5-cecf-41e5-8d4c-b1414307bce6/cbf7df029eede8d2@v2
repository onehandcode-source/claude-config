## 6. test-runner.ts 통합

실행 완료 콜백 내부에서 자동 저장:

```typescript
import { randomUUID } from "node:crypto";
import { saveRunHistory } from "./run-history-manager";

// 실행 완료 후
const runHistory: RunHistory = {
  id: randomUUID(),
  scenarioId: scenario.id,
  scenarioName: scenario.name,
  executedAt: new Date().toISOString(),
  isGolden: false,
  status: overallStatus,   // "passed" | "failed" | "error"
  testCaseResults,
};
saveRunHistory(runHistory);
```

