import { config } from 'dotenv'
config({ path: '.env.local' })

import { createClient } from '@supabase/supabase-js'

const supabaseAdmin = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.SUPABASE_SERVICE_ROLE_KEY!,
  { auth: { autoRefreshToken: false, persistSession: false } }
)

const USERS = [
  { email: 'admin@uracle.co.kr', password: 'admin', role: 'ADMIN' },
  { email: 'user@uracle.co.kr',  password: 'user',  role: 'USER'  },
]

async function seedUsers() {
  console.log('Supabase URL:', process.env.NEXT_PUBLIC_SUPABASE_URL)
  console.log('사용자 시드 시작...\n')

  for (const u of USERS) {
    const { data, error } = await supabaseAdmin.auth.admin.createUser({
      email: u.email,
      password: u.password,
      email_confirm: true,
      app_metadata: { role: u.role },
    })

    if (error) {
      if (error.message.includes('already been registered')) {
        console.log(`⚠️  이미 존재: ${u.email} — 역할 업데이트 시도`)
        const { data: list } = await supabaseAdmin.auth.admin.listUsers()
        const existing = list?.users.find((x) => x.email === u.email)
        if (existing) {
          await supabaseAdmin.auth.admin.updateUserById(existing.id, {
            password: u.password,
            app_metadata: { role: u.role },
          })
          console.log(`✅  비밀번호+역할 업데이트 완료: ${u.email} (${u.role})`)
        }
      } else {
        console.error(`❌  실패: ${u.email} —`, error.message)
      }
    } else {
      console.log(`✅  생성 완료: ${u.email} (${u.role}) — id: ${data.user.id}`)
    }
  }

  console.log('\n완료.')
}

seedUsers()
