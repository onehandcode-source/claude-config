'use client';

import { useState } from 'react';
import { TestResult } from '@/lib/types';

interface ResultViewerProps {
  result: TestResult;
}

export default function ResultViewer({ result }: ResultViewerProps) {
  const [expandedIndex, setExpandedIndex] = useState<number | null>(null);

  const getStatusColor = (status: string) => {
    switch (status) {
      case 'passed':
        return 'bg-green-100 text-green-800 badge-success';
      case 'error':
        return 'bg-red-100 text-red-800 badge-error';
      case 'failed':
        return 'bg-yellow-100 text-yellow-800 badge-warning';
      default:
        return 'bg-gray-100 text-gray-800';
    }
  };

  return (
    <div className="space-y-4">
      {/* 결과 요약 */}
      <div className="bg-gray-50 p-4 rounded-lg border border-gray-200">
        <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
          <div>
            <span className="text-sm text-gray-600">Status</span>
            <p className={`font-bold text-lg badge ${getStatusColor(result.status)}`}>
              {result.status.toUpperCase()}
            </p>
          </div>
          <div>
            <span className="text-sm text-gray-600">Duration</span>
            <p className="font-bold text-lg">{result.executionTime}ms</p>
          </div>
          <div>
            <span className="text-sm text-gray-600">Actions</span>
            <p className="font-bold text-lg">{result.results.length}</p>
          </div>
        </div>
      </div>

      {/* 액션 결과 */}
      <div>
        <h4 className="font-semibold mb-3">Action Results</h4>
        <div className="space-y-2">
          {result.results.map((actionResult, index) => (
            <div key={index} className="border border-gray-200 rounded-lg">
              <button
                onClick={() => setExpandedIndex(expandedIndex === index ? null : index)}
                className="w-full text-left p-4 hover:bg-gray-50 transition-colors flex items-center justify-between"
              >
                <div className="flex-1">
                  <div className="flex items-center gap-3">
                    <span className={`badge ${getStatusColor(actionResult.status)}`}>
                      {actionResult.status.toUpperCase()}
                    </span>
                    <span className="font-semibold text-blue-600">
                      {actionResult.action.type}
                    </span>
                    {actionResult.action.description && (
                      <span className="text-gray-600">
                        - {actionResult.action.description}
                      </span>
                    )}
                  </div>
                </div>
                <span className="text-gray-400">
                  {expandedIndex === index ? '▼' : '▶'}
                </span>
              </button>

              {expandedIndex === index && (
                <div className="px-4 pb-4 bg-gray-50 border-t border-gray-200">
                  {/* 액션 상세 정보 */}
                  <div className="mb-3">
                    <p className="text-sm font-semibold text-gray-700 mb-1">Action Details:</p>
                    <pre className="code-block text-xs overflow-auto">
                      {JSON.stringify(actionResult.action, null, 2)}
                    </pre>
                  </div>

                  {/* 출력 결과 */}
                  {actionResult.output && (
                    <div className="mb-3">
                      <p className="text-sm font-semibold text-gray-700 mb-1">Output:</p>
                      <div className="code-block text-xs overflow-auto">
                        {typeof actionResult.output === 'string'
                          ? actionResult.output
                          : JSON.stringify(actionResult.output, null, 2)}
                      </div>
                    </div>
                  )}

                  {/* 에러 메시지 */}
                  {actionResult.error && (
                    <div className="mb-3">
                      <p className="text-sm font-semibold text-red-700 mb-1">Error:</p>
                      <div className="bg-red-50 border border-red-200 text-red-800 p-2 rounded text-sm">
                        {actionResult.error}
                      </div>
                    </div>
                  )}

                  {/* 스크린샷 */}
                  {actionResult.screenshot && (
                    <div>
                      <p className="text-sm font-semibold text-gray-700 mb-1">Screenshot:</p>
                      <img
                        src={`data:image/png;base64,${actionResult.screenshot}`}
                        alt="Screenshot"
                        className="max-w-full rounded border border-gray-300"
                      />
                    </div>
                  )}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>

      {/* 에러 메시지 */}
      {result.error && (
        <div className="bg-red-50 border-l-4 border-red-600 p-4 rounded">
          <p className="font-semibold text-red-800">Test Error</p>
          <p className="text-red-700 text-sm mt-1">{result.error}</p>
        </div>
      )}
    </div>
  );
}
