## 5. 컴포넌트 작성 규칙

### 5.1 기본 구조

```jsx
// WordList.jsx
interface WordListProps {
    searchParams: WordSearchDto;
}

export function WordList({ searchParams }: WordListProps) {
    const { data, isLoading } = useWordList(searchParams);

    if (isLoading) return <div>로딩 중...</div>;

    return (
        <div className="...">
            {data?.items.map((word) => (
                <WordListItem key={word.id} word={word} />
            ))}
        </div>
    );
}
```

**규칙**:

- `export default` 금지 → named export 사용 (`export function`, `export const`)
- Props 타입은 파일 내부에 `interface {ComponentName}Props` 로 선언
- 컴포넌트 파일 1개에 컴포넌트 1개 원칙 (단, 같은 파일에서만 쓰이는 작은 서브 컴포넌트는 예외)

### 5.2 shadcn/ui + Tailwind 사용 규칙

```jsx
import { cn } from '@/shared/utils/cn';
import { Button } from '@/shared/components/ui/button';

// cn() 으로 조건부 클래스 병합
<div className={cn('base-class', isActive && 'active-class', className)} />

// shadcn 컴포넌트는 shared/components/ui/ 경로에서 import
import { Input } from '@/shared/components/ui/input';
import { Table } from '@/shared/components/ui/table';
```

**cn 유틸**:

```typescript
// shared/utils/cn.js
import { clsx, type ClassValue } from 'clsx';
import { twMerge } from 'tailwind-merge';

export function cn(...inputs: ClassValue[]) {
    return twMerge(clsx(inputs));
}
```

