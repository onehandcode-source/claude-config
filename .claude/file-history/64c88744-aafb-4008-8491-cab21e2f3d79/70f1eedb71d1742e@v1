## 6. 커스텀 Hook 작성 규칙

```typescript
// hooks/useWordList.js

export function useWordList(params: WordSearchDto) {
    return useQuery({
        queryKey: wordQueryKeys.list(params),   // 쿼리 키는 상수 파일에서 관리
        queryFn: () => wordApi.getList(params),
        select: (res) => res.data,              // ApiResponse<T> 언래핑
    });
}

export function useWordDetail(id: number) {
    return useQuery({
        queryKey: wordQueryKeys.detail(id),
        queryFn: () => wordApi.getDetail(id),
        enabled: !!id,                          // id가 없으면 실행 안 함
        select: (res) => res.data,
    });
}

export function useWordSave() {
    const queryClient = useQueryClient();
    return useMutation({
        mutationFn: (data: WordSaveDto) => wordApi.save(data),
        onSuccess: () => {
            queryClient.invalidateQueries({ queryKey: wordQueryKeys.all });
            toast.success('저장되었습니다.');
        },
        onError: () => {
            toast.error('저장에 실패했습니다.');
        },
    });
}
```

**규칙**:

- `use` 접두사 필수
- 서버 상태 조회 → `useQuery`, 서버 상태 변경 → `useMutation`
- `select` 옵션으로 `ApiResponse<T>` 언래핑 처리
- 에러/성공 핸들링은 Hook 내부에서 처리 (컴포넌트에서 중복 처리 금지)

