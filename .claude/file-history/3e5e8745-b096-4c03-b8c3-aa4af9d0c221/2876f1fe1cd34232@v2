  async execute(args) {
    const parsed = InputSchema.safeParse(args)
    if (!parsed.success) throw new McpError(MCP_ERROR.INVALID_PARAMS, 'Invalid params', parsed.error.flatten())
    const { name, kind } = parsed.data
    const tokens = tokenize(name, kind)
    const matched: any[] = []
    const invalidTokens: string[] = []

    for (const token of tokens) {
      const std = await prisma.tbStdWord.findFirst({
        where: { engAbbrNm: { equals: token, mode: 'insensitive' } },
      })
      if (std) {
        matched.push({ token, wordNm: std.stdWordNm, source: 'standard' })
        continue
      }
      const custom = await prisma.tbTrmCustomWord.findFirst({
        where: { wordEngAbbrNm: { equals: token, mode: 'insensitive' }, useYn: 'Y' },
      })
      if (custom) matched.push({ token, wordNm: custom.wordKrNm, source: 'custom' })
      else invalidTokens.push(token)
    }
    return {
      valid: invalidTokens.length === 0,
      tokens, matched, invalidTokens,
      suggestionMessage: invalidTokens.length === 0 ? undefined
        : `${invalidTokens.join(', ')} 은(는) 표준 미등재. register_custom_word로 등록 후 사용 가능.`,
    }
  },
}
```

Tests: all-match, partial-miss (custom fallback), all-miss, db_column 분리, java_field camelCase 분리. Commit: `feat(mcp): validate_identifier tool`.

### 8.4 `suggest_naming`

```typescript
// features/mcp/tools/suggest-naming.ts
import { z } from 'zod'
import { prisma } from '@/lib/prisma'
import { McpError } from '../server'
import { MCP_ERROR } from '../errors'
import type { McpTool } from '../types'

const InputSchema = z.object({
  koreanDescription: z.string().min(1),
  target: z.enum(['db_column', 'java_field', 'both']).default('both'),
})

export const suggestNamingTool: McpTool = {
  name: 'suggest_naming',
  description: '한글 설명으로부터 행안부 표준 약어를 조합한 DB 컬럼/Java 필드명을 제안합니다.',
  permission: 'USER',
  inputSchema: {
    type: 'object',
    properties: {
      koreanDescription: { type: 'string' },
      target: { type: 'string', enum: ['db_column', 'java_field', 'both'] },
    },
    required: ['koreanDescription'],
  },
  async execute(args) {
    const parsed = InputSchema.safeParse(args)
    if (!parsed.success) throw new McpError(MCP_ERROR.INVALID_PARAMS, 'Invalid params')
    const { koreanDescription, target } = parsed.data
    const chunks = koreanDescription.replace(/\s+/g, '').match(/[가-힣]{2,4}/g) ?? []
    const basedOn: Array<{ korean: string; abbr: string }> = []
    for (const chunk of chunks) {
      const w = await prisma.tbStdWord.findFirst({
        where: { stdWordNm: { contains: chunk } }, orderBy: { stdWordNm: 'asc' },
      })
      if (w?.engAbbrNm) basedOn.push({ korean: w.stdWordNm, abbr: w.engAbbrNm.toUpperCase() })
    }
    const abbrs = basedOn.map((b) => b.abbr)
    const dbColumn = abbrs.join('_')
    const javaField = abbrs.length
      ? abbrs[0].toLowerCase() + abbrs.slice(1).map((a) => a[0] + a.slice(1).toLowerCase()).join('')
      : ''
    const confidence = basedOn.length === 0 ? 'low' : basedOn.length >= 2 ? 'high' : 'medium'

    const result: any = { confidence, basedOn }
    if (target === 'db_column' || target === 'both') result.dbColumn = dbColumn
    if (target === 'java_field' || target === 'both') result.javaField = javaField
    return result
  },
}
```

