// features/mcp/server.ts
import { MCP_ERROR } from './errors'
import type { AuthContext, McpTool } from './types'

export type { McpTool } from './types'

export class McpError extends Error {
  constructor(public code: number, message: string, public data?: unknown) { super(message) }
}

export class McpServer {
  private tools: Map<string, McpTool>
  constructor(tools: McpTool[]) {
    this.tools = new Map(tools.map((t) => [t.name, t]))
  }
  listTools() {
    return Array.from(this.tools.values()).map((t) => ({
      name: t.name, description: t.description, inputSchema: t.inputSchema,
    }))
  }
  async callTool(name: string, args: Record<string, unknown>, auth: AuthContext): Promise<unknown> {
    const tool = this.tools.get(name)
    if (!tool) throw new McpError(MCP_ERROR.TOOL_NOT_FOUND, `Tool not found: ${name}`)
    if (tool.permission === 'ADMIN' && auth.role !== 'ADMIN') {
      throw new McpError(MCP_ERROR.PERMISSION_DENIED, 'Admin permission required')
    }
    return tool.execute(args, auth)
  }
}
