// features/mcp/rate-limit/check.ts
import { prisma } from '@/lib/prisma'
import { MCP_ERROR } from '../errors'

const LIMITS = {
  USER: { perMinute: 60, perDay: 5_000 },
  ADMIN: { perMinute: 200, perDay: 20_000 },
} as const

export type RateLimitResult =
  | { ok: true }
  | { ok: false; errorCode: number; message: string; retryAfter: number }

function minuteKey(d: Date): string {
  return d.toISOString().slice(0, 16) // "2026-06-04T15:23"
}

export async function checkRateLimit(tokenId: bigint, role: 'USER' | 'ADMIN'): Promise<RateLimitResult> {
  const now = new Date()
  const windowKey = minuteKey(now)
  const limit = LIMITS[role].perMinute

  const rows = await prisma.$queryRaw<{ count: number }[]>`
    INSERT INTO tb_trm_mcp_rate_limit (token_id, window_key, count)
    VALUES (${tokenId}, ${windowKey}, 1)
    ON CONFLICT (token_id, window_key)
    DO UPDATE SET count = tb_trm_mcp_rate_limit.count + 1
    RETURNING count
  `
  const count = Number(rows[0]?.count ?? 0)
  if (count > limit) {
    const retryAfter = 60 - now.getSeconds()
    return { ok: false, errorCode: MCP_ERROR.RATE_LIMIT, message: 'Rate limit exceeded', retryAfter }
  }
  return { ok: true }
}
```

