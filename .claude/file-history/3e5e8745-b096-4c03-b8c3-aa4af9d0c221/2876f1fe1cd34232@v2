### 8.5 `check_forbidden_in_text`

```typescript
// features/mcp/tools/check-forbidden-in-text.ts
import { z } from 'zod'
import { prisma } from '@/lib/prisma'
import { McpError } from '../server'
import { MCP_ERROR } from '../errors'
import type { McpTool } from '../types'

const InputSchema = z.object({ text: z.string().min(1) })

export const checkForbiddenInTextTool: McpTool = {
  name: 'check_forbidden_in_text',
  description: '입력 텍스트에서 금칙어 출현 위치를 모두 찾습니다.',
  permission: 'USER',
  inputSchema: {
    type: 'object', properties: { text: { type: 'string' } }, required: ['text'],
  },
  async execute(args) {
    const parsed = InputSchema.safeParse(args)
    if (!parsed.success) throw new McpError(MCP_ERROR.INVALID_PARAMS, 'text required')
    const { text } = parsed.data
    const fws = await prisma.tbTrmForbiddenWord.findMany({ where: { useYn: 'Y' } })
    const matches: any[] = []
    const upper = text.toUpperCase()
    for (const fw of fws) {
      const needle = fw.word.toUpperCase()
      let idx = upper.indexOf(needle)
      while (idx !== -1) {
        matches.push({ word: fw.word, position: idx, reason: fw.reason })
        idx = upper.indexOf(needle, idx + 1)
      }
    }
    return { hasForbidden: matches.length > 0, matches }
  },
}
```

