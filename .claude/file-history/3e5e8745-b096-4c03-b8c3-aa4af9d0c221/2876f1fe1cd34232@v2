// app/api/mcp/route.ts
import { NextRequest, NextResponse } from 'next/server'
import { verifyPat } from '@/features/mcp/auth/verify-pat'
import { checkRateLimit } from '@/features/mcp/rate-limit/check'
import { logAudit } from '@/features/mcp/audit/log'
import { McpServer, McpError } from '@/features/mcp/server'
import { MCP_ERROR } from '@/features/mcp/errors'
import { ALL_TOOLS } from '@/features/mcp/tools'

const server = new McpServer(ALL_TOOLS)

function jsonRpcResponse(id: unknown, result: unknown) {
  return NextResponse.json({ jsonrpc: '2.0', id, result })
}
function jsonRpcError(id: unknown, code: number, message: string, status = 200, data?: unknown) {
  const body: any = { jsonrpc: '2.0', id, error: { code, message } }
  if (data) body.error.data = data
  return NextResponse.json(body, { status })
}

export async function POST(req: NextRequest) {
  const startedAt = Date.now()
  let body: any
  try { body = await req.json() }
  catch { return jsonRpcError(null, MCP_ERROR.PARSE_ERROR, 'Parse error', 400) }
  const { id, method, params } = body ?? {}
  if (!method) return jsonRpcError(id, MCP_ERROR.INVALID_REQUEST, 'Invalid Request', 400)

  if (method === 'initialize') {
    return jsonRpcResponse(id, {
      protocolVersion: '2025-03-26',
      capabilities: { tools: {} },
      serverInfo: { name: 'trmdict', version: '1.0.0' },
    })
  }
  if (method === 'notifications/initialized') {
    return new NextResponse(null, { status: 204 })
  }

  const auth = await verifyPat(req.headers.get('authorization'))
  if (!auth.ok) {
    void logAudit({ tokenId: null, userId: null, toolName: '<auth>', params: {}, status: 'denied', errorCode: auth.errorCode })
    return jsonRpcError(id, auth.errorCode, auth.message, 401)
  }

  const rl = await checkRateLimit(auth.tokenId, auth.role)
  if (!rl.ok) {
    return jsonRpcError(id, rl.errorCode, rl.message, 429, { retryAfter: rl.retryAfter })
  }

  try {
    let result: unknown
    if (method === 'tools/list') {
      result = { tools: server.listTools() }
    } else if (method === 'tools/call') {
      const name = params?.name as string
      const args = (params?.arguments as Record<string, unknown>) ?? {}
      const toolResult = await server.callTool(name, args, { tokenId: auth.tokenId, userId: auth.userId, role: auth.role })
      void logAudit({
        tokenId: auth.tokenId, userId: auth.userId, toolName: name,
        params: args, status: 'success', latencyMs: Date.now() - startedAt,
      })
      result = { content: [{ type: 'text', text: JSON.stringify(toolResult) }] }
    } else {
      return jsonRpcError(id, MCP_ERROR.METHOD_NOT_FOUND, `Method not found: ${method}`)
    }
    return jsonRpcResponse(id, result)
  } catch (e) {
    if (e instanceof McpError) {
      const status = e.code === MCP_ERROR.PERMISSION_DENIED ? 403 : 200
      void logAudit({
        tokenId: auth.tokenId, userId: auth.userId, toolName: params?.name ?? '<unknown>',
        params: params?.arguments ?? {}, status: 'denied', errorCode: e.code, latencyMs: Date.now() - startedAt,
      })
      return jsonRpcError(id, e.code, e.message, status)
    }
    console.error('[mcp] internal error', e)
    void logAudit({
      tokenId: auth.tokenId, userId: auth.userId, toolName: params?.name ?? '<unknown>',
      params: params?.arguments ?? {}, status: 'error', errorCode: MCP_ERROR.INTERNAL_ERROR, latencyMs: Date.now() - startedAt,
    })
    return jsonRpcError(id, MCP_ERROR.INTERNAL_ERROR, 'Internal error')
  }
}
