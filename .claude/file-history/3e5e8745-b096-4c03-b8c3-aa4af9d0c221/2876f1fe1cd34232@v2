import { describe, it, expect } from 'vitest'
import { verifyPat } from '../verify-pat'
import { prismaMock } from '@/vitest.setup'

describe('verifyPat', () => {
  it('returns auth context for valid active token', async () => {
    prismaMock.tbTrmMcpToken.findUnique.mockResolvedValue({
      id: 1n, tokenHash: 'hash', userId: 'user-uuid', revokedAt: null, expiresAt: null, scopes: ['read'],
    } as any)
    prismaMock.authUser.findUnique.mockResolvedValue({ id: 'user-uuid', role: 'USER' } as any)

    const result = await verifyPat('Bearer trmdict_pat_xxx')
    expect(result.ok).toBe(true)
    if (result.ok) {
      expect(result.tokenId).toBe(1n)
      expect(result.userId).toBe('user-uuid')
      expect(result.role).toBe('USER')
    }
  })

  it('returns -32001 when header missing', async () => {
    const r = await verifyPat(null)
    expect(r.ok).toBe(false)
    if (!r.ok) expect(r.errorCode).toBe(-32001)
  })

  it('returns -32002 when token not found in DB', async () => {
    prismaMock.tbTrmMcpToken.findUnique.mockResolvedValue(null)
    const r = await verifyPat('Bearer trmdict_pat_xxx')
    expect(r.ok).toBe(false)
    if (!r.ok) expect(r.errorCode).toBe(-32002)
  })

  it('returns -32002 when token revoked', async () => {
    prismaMock.tbTrmMcpToken.findUnique.mockResolvedValue({
      id: 1n, tokenHash: 'h', userId: 'u', revokedAt: new Date(), expiresAt: null,
    } as any)
    const r = await verifyPat('Bearer trmdict_pat_xxx')
    expect(r.ok).toBe(false)
    if (!r.ok) expect(r.errorCode).toBe(-32002)
  })

  it('returns -32002 when token expired', async () => {
    prismaMock.tbTrmMcpToken.findUnique.mockResolvedValue({
      id: 1n, tokenHash: 'h', userId: 'u', revokedAt: null,
      expiresAt: new Date(Date.now() - 1000),
    } as any)
    const r = await verifyPat('Bearer trmdict_pat_xxx')
    expect(r.ok).toBe(false)
    if (!r.ok) expect(r.errorCode).toBe(-32002)
  })

  it('updates lastUsedAt asynchronously (fire-and-forget)', async () => {
    prismaMock.tbTrmMcpToken.findUnique.mockResolvedValue({
      id: 1n, tokenHash: 'h', userId: 'u', revokedAt: null, expiresAt: null,
    } as any)
    prismaMock.authUser.findUnique.mockResolvedValue({ id: 'u', role: 'USER' } as any)
    await verifyPat('Bearer trmdict_pat_xxx')
    expect(prismaMock.tbTrmMcpToken.update).toHaveBeenCalledWith({
      where: { id: 1n }, data: { lastUsedAt: expect.any(Date) },
    })
  })
})
