import { create } from 'zustand';

export const useLoadingStore = create((set) => ({
    keys: new Set(),
    isLoading: false,
    start: (key) =>
        set((state) => {
            const next = new Set(state.keys);
            next.add(key);
            return { keys: next, isLoading: next.size > 0 };
        }),
    end: (key) =>
        set((state) => {
            const next = new Set(state.keys);
            next.delete(key);
            return { keys: next, isLoading: next.size > 0 };
        }),
}));
