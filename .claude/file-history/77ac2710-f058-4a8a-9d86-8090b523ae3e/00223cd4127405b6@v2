// module/mcp/tool/ValidateJavaIdentifierTool.java
@Slf4j
@Component
@RequiredArgsConstructor
public class ValidateJavaIdentifierTool implements McpTool {
    private final WordRepository wordRepository;

    @Override public String getName() { return "validate_java_identifier"; }
    @Override public String getDescription() {
        return "Java 식별자를 camelCase 분리 후 각 단어를 표준 단어 DB에서 확인합니다.";
    }

    @Override
    public Map<String, Object> getInputSchema() {
        Map<String, Object> schema = new HashMap<>();
        schema.put("type", "object");
        Map<String, Object> props = new HashMap<>();
        props.put("identifier", prop("string", "Java 식별자 (예: userName)"));
        props.put("type", prop("string", "class | field | method | variable"));
        schema.put("properties", props);
        schema.put("required", Arrays.asList("identifier", "type"));
        return schema;
    }

    @Override
    public Object execute(Map<String, Object> arguments) {
        String identifier = (String) arguments.get("identifier");
        // camelCase/PascalCase 분리
        String[] tokens = identifier.split("(?<=[a-z])(?=[A-Z])|(?<=[A-Z])(?=[A-Z][a-z])");

        List<Map<String, Object>> words = new ArrayList<>();
        List<String> invalidTokens = new ArrayList<>();
        List<String> abbrTokens = new ArrayList<>();

        for (String token : tokens) {
            List<WordEntity> matches = wordRepository.findByStdWordEngNmContainingIgnoreCase(token);
            if (!matches.isEmpty()) {
                WordEntity w = matches.get(0);
                Map<String, Object> item = new HashMap<>();
                item.put("token", token);
                item.put("std_word_nm", w.getStdWordNm());
                item.put("std_abbr", w.getStdWordEngAbbrNm());
                words.add(item);
                if (w.getStdWordEngAbbrNm() != null) {
                    abbrTokens.add(w.getStdWordEngAbbrNm().toUpperCase());
                }
            } else {
                invalidTokens.add(token);
            }
        }

        Map<String, Object> result = new HashMap<>();
        result.put("valid", invalidTokens.isEmpty());
        result.put("words", words);
        result.put("db_column_equivalent", String.join("_", abbrTokens));
        result.put("invalid_tokens", invalidTokens);
        return result;
    }

    private Map<String, Object> prop(String type, String desc) {
        Map<String, Object> p = new HashMap<>();
        p.put("type", type); p.put("description", desc); return p;
    }
}
