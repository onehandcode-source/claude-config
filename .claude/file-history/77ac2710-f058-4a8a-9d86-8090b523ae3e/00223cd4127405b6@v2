    private final WordRepository wordRepository;

    @Override public String getName() { return "suggest_db_column_name"; }
    @Override public String getDescription() {
        return "한글 설명을 입력하면 표준 약어 조합으로 컬럼명을 제안합니다.";
    }

    @Override
    public Map<String, Object> getInputSchema() {
        Map<String, Object> schema = new HashMap<>();
        schema.put("type", "object");
        Map<String, Object> props = new HashMap<>();
        props.put("korean_description", prop("string", "한글 설명 (예: 사용자명)"));
        schema.put("properties", props);
        schema.put("required", Arrays.asList("korean_description"));
        return schema;
    }

    @Override
    public Object execute(Map<String, Object> arguments) {
        String desc = (String) arguments.get("korean_description");
        List<WordEntity> words = wordRepository.findByStdWordNmContaining(desc);

        List<Map<String, Object>> basedOn = new ArrayList<>();
        List<String> abbrTokens = new ArrayList<>();

        for (WordEntity w : words) {
            if (w.getStdWordEngAbbrNm() != null) {
                Map<String, Object> item = new HashMap<>();
                item.put("korean", w.getStdWordNm());
                item.put("abbr", w.getStdWordEngAbbrNm());
                basedOn.add(item);
                abbrTokens.add(w.getStdWordEngAbbrNm().toUpperCase());
            }
        }

        String confidence = basedOn.isEmpty() ? "low" : (basedOn.size() >= 2 ? "high" : "medium");

        Map<String, Object> result = new HashMap<>();
        result.put("suggested_name", String.join("_", abbrTokens));
        result.put("confidence", confidence);
        result.put("based_on", basedOn);
        return result;
    }

