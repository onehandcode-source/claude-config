@Slf4j
@Component
@RequiredArgsConstructor
public class ValidateDbNameTool implements McpTool {
    private final WordRepository wordRepository;
    private final CustomWordRepository customWordRepository;

    @Override public String getName() { return "validate_db_name"; }

    @Override
    public String getDescription() {
        return "DB 컬럼명 또는 테이블명이 행안부 표준 약어 규칙에 부합하는지 검증합니다.";
    }

    @Override
    public Map<String, Object> getInputSchema() {
        Map<String, Object> schema = new HashMap<>();
        schema.put("type", "object");
        Map<String, Object> props = new HashMap<>();
        props.put("name", prop("string", "검사할 이름 (예: USER_NM)"));
        props.put("type", prop("string", "column | table"));
        schema.put("properties", props);
        schema.put("required", Arrays.asList("name", "type"));
        return schema;
    }

    @Override
    public Object execute(Map<String, Object> arguments) {
        String name = ((String) arguments.get("name")).toUpperCase();
        String[] tokens = name.split("_");

        List<Map<String, Object>> matched = new ArrayList<>();
        List<String> invalidTokens = new ArrayList<>();

        for (String token : tokens) {
            if (token.isEmpty()) continue;
            Optional<WordEntity> std = wordRepository.findByStdWordEngAbbrNmIgnoreCase(token);
            if (std.isPresent()) {
                Map<String, Object> m = new HashMap<>();
                m.put("token", token);
                m.put("word_nm", std.get().getStdWordNm());
                m.put("source", "standard");
                matched.add(m);
            } else {
                List<CustomWord> custom = customWordRepository.findByWordEngAbbrNmIgnoreCaseAndUseYn(token, "Y");
                if (!custom.isEmpty()) {
                    Map<String, Object> m = new HashMap<>();
                    m.put("token", token);
                    m.put("word_nm", custom.get(0).getWordKrNm());
                    m.put("source", "custom");
                    matched.add(m);
                } else {
                    invalidTokens.add(token);
                }
            }
        }

        Map<String, Object> result = new HashMap<>();
        result.put("valid", invalidTokens.isEmpty());
        result.put("tokens", Arrays.asList(tokens));
        result.put("matched", matched);
        result.put("invalid_tokens", invalidTokens);
        if (!invalidTokens.isEmpty()) {
            result.put("suggestions", buildSuggestion(invalidTokens));
        }
        return result;
    }

    private String buildSuggestion(List<String> invalids) {
        return String.join(", ", invalids) + " 은(는) 표준 미등재. create_custom_word 로 비표준 용어 등록 후 사용 가능.";
    }

    private Map<String, Object> prop(String type, String desc) {
        Map<String, Object> p = new HashMap<>();
        p.put("type", type); p.put("description", desc); return p;
    }
}
