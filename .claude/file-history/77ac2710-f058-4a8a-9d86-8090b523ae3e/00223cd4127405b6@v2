// module/mcp/tool/WordSearchTool.java
@Slf4j
@Component
@RequiredArgsConstructor
public class WordSearchTool implements McpTool {
    private final WordRepository wordRepository;

    @Override
    public String getName() { return "search_standard_word"; }

    @Override
    public String getDescription() {
        return "행안부 표준 단어 DB에서 단어를 검색합니다. search_type: korean | english_abbr | english";
    }

    @Override
    public Map<String, Object> getInputSchema() {
        Map<String, Object> schema = new HashMap<>();
        schema.put("type", "object");
        Map<String, Object> props = new HashMap<>();
        props.put("query", singleProp("string", "검색어"));
        props.put("search_type", singleProp("string", "korean | english_abbr | english"));
        schema.put("properties", props);
        schema.put("required", Arrays.asList("query", "search_type"));
        return schema;
    }

    @Override
    public Object execute(Map<String, Object> arguments) {
        String query = (String) arguments.get("query");
        String searchType = (String) arguments.get("search_type");

        List<WordEntity> words;
        switch (searchType) {
            case "english_abbr":
                words = wordRepository.findByStdWordEngAbbrNmIgnoreCase(query)
                    .map(Arrays::asList).orElse(Collections.emptyList());
                break;
            case "english":
                words = wordRepository.findByStdWordEngNmContainingIgnoreCase(query);
                break;
            default: // korean
                words = wordRepository.findByStdWordNmContaining(query);
        }

        return words.stream().map(w -> {
            Map<String, Object> item = new HashMap<>();
            item.put("std_word_nm", w.getStdWordNm());
            item.put("std_word_eng_abbr_nm", w.getStdWordEngAbbrNm());
            item.put("std_word_eng_nm", w.getStdWordEngNm());
            return item;
        }).collect(Collectors.toList());
    }

    private Map<String, Object> singleProp(String type, String desc) {
        Map<String, Object> p = new HashMap<>();
        p.put("type", type);
        p.put("description", desc);
        return p;
    }
}
