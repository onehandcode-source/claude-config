// module/mcp/controller/McpSseController.java
@Slf4j
@RestController
@RequiredArgsConstructor
@RequestMapping("/api/v1/mcp")
public class McpSseController {
    private final McpSessionManager sessionManager;

    @GetMapping(value = "/sse", produces = MediaType.TEXT_EVENT_STREAM_VALUE)
    public SseEmitter connect(HttpServletRequest request) {
        String sessionId = UUID.randomUUID().toString();
        SseEmitter emitter = sessionManager.createSession(sessionId);

        String baseUrl = request.getScheme() + "://" + request.getServerName() + ":" + request.getServerPort();
        String postUrl = baseUrl + "/api/v1/mcp/messages?sessionId=" + sessionId;

        try {
            emitter.send(SseEmitter.event().name("endpoint").data(postUrl));
        } catch (IOException e) {
            log.error("SSE endpoint event 전송 실패: {}", e.getMessage());
            emitter.completeWithError(e);
        }

        return emitter;
    }
}
