@Slf4j
@Service
@RequiredArgsConstructor
public class CustomWordService {
    private final CustomWordRepository customWordRepository;

    @Transactional(readOnly = true)
    public List<CustomWordVo> search(String query) {
        return customWordRepository.findByWordKrNmContainingAndUseYn(query, "Y")
            .stream()
            .map(w -> CustomWordVo.builder()
                .id(w.getCustomWordSn())
                .koreanName(w.getWordKrNm())
                .englishName(w.getWordEngNm())
                .englishAbbr(w.getWordEngAbbrNm())
                .reason(w.getReasonCn())
                .build())
            .collect(Collectors.toList());
    }

    @Transactional
    public CustomWordVo create(String koreanName, String englishName, String englishAbbr, String reason) {
        CustomWord word = CustomWord.builder()
            .wordKrNm(koreanName)
            .wordEngNm(englishName)
            .wordEngAbbrNm(englishAbbr)
            .reasonCn(reason)
            .useYn("Y")
            .regDt(LocalDateTime.now())
            .build();
        CustomWord saved = customWordRepository.save(word);
        return CustomWordVo.builder()
            .id(saved.getCustomWordSn())
            .koreanName(saved.getWordKrNm())
            .englishName(saved.getWordEngNm())
            .englishAbbr(saved.getWordEngAbbrNm())
            .reason(saved.getReasonCn())
            .build();
    }
}
