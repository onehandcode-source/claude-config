@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
    :root {
        color: #0f172a;
        background: #f8fafc;
        font-family: 'Segoe UI', sans-serif;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
    }

    button,
    input,
    select {
        font: inherit;
    }
}
