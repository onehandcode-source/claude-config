import { describe, expect, test, vi, beforeEach } from 'vitest';
import { getForbiddenById, searchForbiddens } from './forbiddenApi';
import { axiosInstance, unwrapResponse } from '@/core/api/axiosInstance';

vi.mock('@/core/api/axiosInstance', () => ({
    axiosInstance: {
        post: vi.fn(),
        get: vi.fn(),
    },
    unwrapResponse: vi.fn(),
}));

describe('forbiddenApi', () => {
    beforeEach(() => {
        vi.clearAllMocks();
    });

    test('posts forbidden search requests to the search endpoint', async () => {
        const payload = { page: 1, size: 20, phwrdNm: '금지어' };
        const response = { data: { success: true, data: { items: [] } } };
        const unwrapped = { items: [] };

        axiosInstance.post.mockResolvedValue(response);
        unwrapResponse.mockReturnValue(unwrapped);

        const result = await searchForbiddens(payload);

        expect(axiosInstance.post).toHaveBeenCalledWith('/forbiddens/search', payload);
        expect(unwrapResponse).toHaveBeenCalledWith(response);
        expect(result).toBe(unwrapped);
    });

    test('gets a forbidden detail record by id', async () => {
        const response = { data: { success: true, data: { id: 7 } } };
        const unwrapped = { id: 7 };

        axiosInstance.get.mockResolvedValue(response);
        unwrapResponse.mockReturnValue(unwrapped);

        const result = await getForbiddenById(7);

        expect(axiosInstance.get).toHaveBeenCalledWith('/forbiddens/7');
        expect(unwrapResponse).toHaveBeenCalledWith(response);
        expect(result).toBe(unwrapped);
    });
});
