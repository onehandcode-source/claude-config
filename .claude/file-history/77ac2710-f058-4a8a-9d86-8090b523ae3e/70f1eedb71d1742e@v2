## 7. API 함수 작성 규칙

```js
// wordApi.js
import { axiosInstance } from '@/core/api/axiosInstance';

export const wordApi = {
    getList: (params) =>
        axiosInstance.post('/api/v1/words/search', params),

    getDetail: (id) =>
        axiosInstance.get(`/api/v1/words/${id}`),

    save: (data) =>
        axiosInstance.post('/api/v1/words', data),

    update: (id, data) =>
        axiosInstance.put(`/api/v1/words/${id}`, data),

    remove: (id) =>
        axiosInstance.delete(`/api/v1/words/${id}`),
};
```

**Query Key 상수 패턴**:

```js
// word.constants.js
export const wordQueryKeys = {
    all: ['words'],
    list: (params) => ['words', 'list', params],
    detail: (id) => ['words', 'detail', id],
};
```

