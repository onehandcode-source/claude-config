import '@testing-library/jest-dom/vitest';
import { render, screen, within } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import { DataGrid } from './DataGrid';

const EMPTY_ROWS = [];
const EMPTY_COLUMN_DEFS = [];
let lastGridProps;

vi.mock('ag-grid-community', () => ({
    ModuleRegistry: { registerModules: vi.fn() },
    AllCommunityModule: {},
    themeQuartz: { withParams: vi.fn().mockReturnValue('mock-theme') },
}));

vi.mock('ag-grid-react', () => ({
    AgGridReact: vi.fn((props) => {
        lastGridProps = props;
        const {
            rowData = EMPTY_ROWS,
            columnDefs = EMPTY_COLUMN_DEFS,
            onRowClicked,
            onSortChanged,
            onSelectionChanged,
            rowSelection,
        } = props;

        const handleSort = (col) => {
            onSortChanged?.({
                api: {
                    getColumnState: () =>
                        columnDefs.map((c) =>
                            c.field === col.field
                                ? { colId: c.field, sort: 'asc' }
                                : { colId: c.field, sort: null },
                        ),
                },
            });
        };

        const handleSelectAll = () => {
            onSelectionChanged?.({ api: { getSelectedRows: () => rowData } });
        };

        return (
            <table>
                <thead>
                    <tr>
                        {rowSelection?.mode === 'multiRow' && (
                            <th>
                                <input type='checkbox' aria-label='Select all rows' onChange={handleSelectAll} />
                            </th>
                        )}
                        {columnDefs.map((col) => (
                            <th key={col.field}>
                                {col.sortable ? (
                                    <button
                                        type='button'
                                        aria-label={`Sort by ${col.headerName}`}
                                        onClick={() => handleSort(col)}
                                    >
                                        {col.headerName}
                                    </button>
                                ) : (
                                    col.headerName
                                )}
                            </th>
                        ))}
                    </tr>
                </thead>
                <tbody>
                    {rowData.map((row) => (
                        <tr key={row.id} onClick={() => onRowClicked?.({ data: row })}>
                            {columnDefs.map((col) => (
                                <td key={col.field}>{String(row[col.field] ?? '')}</td>
                            ))}
                        </tr>
                    ))}
                </tbody>
            </table>
        );
    }),
}));

const columns = [
    { key: 'name', header: 'Name', sortable: true },
    { key: 'status', header: 'Status', sortable: false },
];

const pageData = {
    items: [
        { id: 1, name: 'Alpha', status: 'ACTIVE' },
        { id: 2, name: 'Beta', status: 'PENDING' },
    ],
    page: 1,
    size: 10,
    totalElements: 12,
    totalPages: 2,
};

describe('DataGrid', () => {
    beforeEach(() => {
        lastGridProps = undefined;
    });

    test('renders rows and emits row click and sorting', async () => {
        const user = userEvent.setup();
        const onRowClick = vi.fn();
        const onSortChange = vi.fn();

        render(
            <DataGrid columns={columns} pageData={pageData} onRowClick={onRowClick} onSortChange={onSortChange} />,
        );

        await user.click(screen.getByRole('button', { name: /sort by name/i }));
        await user.click(screen.getByText('Alpha'));

        expect(onSortChange).toHaveBeenCalledWith({ active: 'name', direction: 'asc' });
        expect(onRowClick).toHaveBeenCalledWith(pageData.items[0]);
        expect(lastGridProps.autoSizeStrategy).toEqual({ type: 'fitGridWidth', defaultMinWidth: 120 });
        expect(lastGridProps.localeText.contains).toBe('\uD3EC\uD568');
        expect(lastGridProps.localeText.pageSizeSelectorLabel).toBe('\uD398\uC774\uC9C0 \uD06C\uAE30');
    });

    test('keeps page size select in the toolbar and pagination in the footer center', async () => {
        const user = userEvent.setup();
        const onSelectionChange = vi.fn();
        const onPageChange = vi.fn();

        render(
            <DataGrid
                columns={columns}
                pageData={pageData}
                selectable
                onSelectionChange={onSelectionChange}
                onPageChange={onPageChange}
            />,
        );

        await user.click(screen.getByRole('checkbox', { name: 'Select all rows' }));
        await user.click(screen.getByRole('button', { name: '2' }));

        expect(onSelectionChange).toHaveBeenLastCalledWith(pageData.items);
        expect(onPageChange).toHaveBeenCalledWith({ page: 2, size: 10 });
        expect(within(screen.getByTestId('grid-toolbar')).getByRole('combobox', { name: 'Page size' })).toBeInTheDocument();
        expect(within(screen.getByTestId('grid-footer')).queryByRole('combobox', { name: 'Page size' })).toBeNull();
        expect(screen.getByTestId('grid-footer')).toHaveClass('grid-cols-[1fr_auto_1fr]');
        expect(screen.getByText('\uD398\uC774\uC9C0 1 / 2 · \uCD1D 12\uAC74')).toBeInTheDocument();
    });
});
