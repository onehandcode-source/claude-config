import { AgGridReact } from 'ag-grid-react';
import { AllCommunityModule, ModuleRegistry, themeQuartz } from 'ag-grid-community';
import { useCallback, useMemo, useRef, useState } from 'react';
import * as XLSX from 'xlsx';
import { cn } from '@/lib/utils';
import { Button } from '../ui/button';

ModuleRegistry.registerModules([AllCommunityModule]);

const gridTheme = themeQuartz.withParams({
    backgroundColor: 'hsl(var(--card))',
    foregroundColor: 'hsl(var(--foreground))',
    borderColor: 'hsl(var(--border))',
    headerBackgroundColor: 'hsl(var(--muted))',
    headerTextColor: 'hsl(var(--muted-foreground))',
    headerFontWeight: 600,
    rowHoverColor: 'hsl(var(--accent))',
    selectedRowBackgroundColor: 'hsl(var(--secondary))',
    fontFamily: 'inherit',
    fontSize: 13,
    rowHeight: 40,
    headerHeight: 40,
});

const DEFAULT_PAGE_SIZE_OPTIONS = [10, 20, 50, 100];
const DEFAULT_COLUMNS = [];
const DEFAULT_DENSITIES = {
    comfortable: { rowHeight: 40, headerHeight: 40 },
    compact: { rowHeight: 32, headerHeight: 34 },
    spacious: { rowHeight: 48, headerHeight: 44 },
};

const KOREAN_LOCALE_TEXT = {
    pageSizeSelectorLabel: '\uD398\uC774\uC9C0 \uD06C\uAE30',
    ariaPageSizeSelectorLabel: '\uD398\uC774\uC9C0 \uD06C\uAE30',
    applyFilter: '\uC801\uC6A9',
    clearFilter: '\uC9C0\uC6B0\uAE30',
    resetFilter: '\uCD08\uAE30\uD654',
    cancelFilter: '\uCDE8\uC18C',
    textFilter: '\uD14D\uC2A4\uD2B8 \uD544\uD130',
    numberFilter: '\uC22B\uC790 \uD544\uD130',
    bigintFilter: '\uC22B\uC790 \uD544\uD130',
    dateFilter: '\uB0A0\uC9DC \uD544\uD130',
    setFilter: '\uC138\uD2B8 \uD544\uD130',
    filterOoo: '\uD544\uD130...',
    empty: '\uBE48 \uAC12',
    equals: '\uAC19\uC74C',
    notEqual: '\uAC19\uC9C0 \uC54A\uC74C',
    lessThan: '\uC791\uC74C',
    greaterThan: '\uD07C',
    inRange: '\uBC94\uC704',
    inRangeStart: '\uC2DC\uC791',
    inRangeEnd: '\uC885\uB8CC',
    lessThanOrEqual: '\uC774\uD558',
    greaterThanOrEqual: '\uC774\uC0C1',
    contains: '\uD3EC\uD568',
    notContains: '\uD3EC\uD568 \uC548 \uD568',
    startsWith: '\uC2DC\uC791 \uBB38\uC790',
    endsWith: '\uB05D \uBB38\uC790',
    blank: '\uBE48\uAC12',
    notBlank: '\uAC12 \uC788\uC74C',
    before: '\uC804',
    after: '\uD6C4',
    andCondition: '\uADF8\uB807\uACE0',
    orCondition: '\uB610\uB294',
    dateFormatOoo: '\uB0A0\uC9DC \uD615\uC2DD',
};

const buildPageItems = (currentPage, totalPages) => {
    if (totalPages <= 1) {
        return [];
    }

    if (totalPages <= 7) {
        return Array.from({ length: totalPages }, (_, index) => ({ type: 'page', value: index + 1 }));
    }

    const pages = new Set([1, totalPages, currentPage - 1, currentPage, currentPage + 1]);
    const ordered = [...pages]
        .filter((page) => page >= 1 && page <= totalPages)
        .sort((a, b) => a - b);

    const items = [];
    let lastPage = 0;

    ordered.forEach((page) => {
        if (page - lastPage > 1) {
            items.push({ type: 'ellipsis', key: `ellipsis-${lastPage}-${page}` });
        }

        items.push({ type: 'page', value: page });
        lastPage = page;
    });

    return items;
};

const getCellStyle = (align) => {
    if (align === 'center') return { textAlign: 'center' };
    if (align === 'end') return { textAlign: 'right' };
    return { textAlign: 'left' };
};

export const DataGrid = ({
    columns = DEFAULT_COLUMNS,
    pageData = null,
    pageSizeOptions = DEFAULT_PAGE_SIZE_OPTIONS,
    selectable = false,
    onRefresh,
    onPageChange,
    onSortChange,
    onSelectionChange,
    onRowClick,
}) => {
    const gridRef = useRef(null);
    const rows = pageData?.items ?? [];
    const [density, setDensity] = useState('comfortable');
    const [selectedRows, setSelectedRows] = useState([]);
    const [visibleColumns, setVisibleColumns] = useState(
        () => new Set(columns.map((column) => column.key)),
    );

    const pageItems = useMemo(
        () => buildPageItems(pageData?.page ?? 1, pageData?.totalPages ?? 1),
        [pageData?.page, pageData?.totalPages],
    );
    const densityParams = DEFAULT_DENSITIES[density] ?? DEFAULT_DENSITIES.comfortable;

    const columnDefs = useMemo(
        () =>
            columns.map((col) => ({
                field: col.key,
                headerName: col.header,
                sortable: col.sortable ?? false,
                filter: col.filter ?? 'agTextColumnFilter',
                filterParams: col.filterParams,
                width: col.width ?? 160,
                minWidth: col.minWidth ?? 120,
                pinned: col.pin ?? undefined,
                hide: !visibleColumns.has(col.key),
                cellStyle: getCellStyle(col.align),
                cellRenderer: col.cell
                    ? ({ value, data }) => col.cell({ value, row: data })
                    : undefined,
                suppressMovable: true,
                resizable: true,
            })),
        [columns, visibleColumns],
    );

    const selectedCount = selectable ? selectedRows.length : 0;

    const onSortChanged = useCallback(
        (event) => {
            const sorted = event.api.getColumnState().find((c) => c.sort);
            if (sorted) {
                onSortChange?.({ active: sorted.colId, direction: sorted.sort });
            } else {
                onSortChange?.({ active: null, direction: '' });
            }
        },
        [onSortChange],
    );

    const onSelectionChanged = useCallback(
        (event) => {
            const nextRows = event.api.getSelectedRows();
            setSelectedRows(nextRows);
            onSelectionChange?.(nextRows);
        },
        [onSelectionChange],
    );

    const handleExcelExport = useCallback(() => {
        const exportRows = selectedRows.length > 0 ? selectedRows : rows;
        const activeColumns = columns.filter((column) => visibleColumns.has(column.key));
        const headers = activeColumns.map((column) => column.header);
        const data = exportRows.map((row) =>
            activeColumns.map((column) => row[column.key] ?? ''),
        );

        const ws = XLSX.utils.aoa_to_sheet([headers, ...data]);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, 'Sheet1');
        XLSX.writeFile(wb, 'export.xlsx');
    }, [columns, rows, selectedRows, visibleColumns]);

    const handleCsvExport = useCallback(() => {
        const exportRows = selectedRows.length > 0 ? selectedRows : rows;
        const activeColumns = columns.filter((column) => visibleColumns.has(column.key));
        const escapeCsv = (value) => {
            const text = `${value ?? ''}`;
            return `"${text.replace(/"/g, '""')}"`;
        };

        const csvBody = [
            activeColumns.map((column) => escapeCsv(column.header)).join(','),
            ...exportRows.map((row) => activeColumns.map((column) => escapeCsv(row[column.key])).join(',')),
        ].join('\n');

        const blob = new Blob([csvBody], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const anchor = document.createElement('a');
        anchor.href = url;
        anchor.download = 'export.csv';
        anchor.click();
        URL.revokeObjectURL(url);
    }, [columns, rows, selectedRows, visibleColumns]);

    const toggleColumnVisibility = useCallback((columnKey) => {
        setVisibleColumns((current) => {
            const next = new Set(current);
            if (next.has(columnKey)) {
                if (next.size === 1) {
                    return next;
                }
                next.delete(columnKey);
            } else {
                next.add(columnKey);
            }
            return next;
        });
    }, []);

    const restoreAllColumns = useCallback(() => {
        setVisibleColumns(new Set(columns.map((column) => column.key)));
    }, [columns]);

    const clearSelection = useCallback(() => {
        setSelectedRows([]);
        gridRef.current?.api?.deselectAll?.();
    }, []);

    return (
        <section className='w-full max-w-full overflow-hidden rounded-2xl border border-border bg-card text-card-foreground shadow-lg'>
            <div
                data-testid='grid-toolbar'
                className='flex flex-wrap items-start justify-between gap-3 border-b border-border bg-muted/30 px-4 py-3'
            >
                <div className='flex flex-wrap items-center gap-3 text-sm text-muted-foreground'>
                    <span className='font-medium text-foreground'>
                        {pageData ? `\uCD1D ${pageData.totalElements}\uAC74` : '\uCD1D 0\uAC74'}
                    </span>
                    {selectable ? <span>\uC120\uD0DD {selectedCount}\uAC74</span> : null}
                    <label className='flex items-center gap-2'>
                        <span>\uB9C1\uB3C4</span>
                        <select
                            aria-label='Grid density'
                            className='h-9 rounded-md border border-input bg-background px-3 text-sm text-foreground shadow-sm'
                            value={density}
                            onChange={(event) => setDensity(event.target.value)}
                        >
                            <option value='compact'>\uCEF4\uD328\uD2B8</option>
                            <option value='comfortable'>\uBCF4\uD1B5</option>
                            <option value='spacious'>\uC5EC\uC720</option>
                        </select>
                    </label>
                </div>

                <div className='flex flex-wrap items-center justify-end gap-2'>
                    <select
                        aria-label='Page size'
                        className='h-9 rounded-md border border-input bg-background px-3 text-sm text-foreground shadow-sm'
                        value={pageData?.size ?? pageSizeOptions[0]}
                        onChange={(event) =>
                            onPageChange?.({
                                page: 1,
                                size: Number(event.target.value),
                            })
                        }
                    >
                        {pageSizeOptions.map((option) => (
                            <option key={option} value={option}>
                                {option} / page
                            </option>
                        ))}
                    </select>

                    <details className='relative'>
                        <summary className='list-none'>
                            <Button variant='outline' size='sm' type='button'>
                                \uCEEC\uB7FC
                            </Button>
                        </summary>
                        <div className='absolute right-0 z-10 mt-2 w-56 rounded-xl border border-border bg-card p-3 shadow-xl'>
                            <div className='mb-2 flex items-center justify-between'>
                                <span className='text-sm font-medium text-foreground'>\uD604\uC7AC \uCEEC\uB7FC</span>
                                <button
                                    type='button'
                                    className='text-xs text-muted-foreground hover:text-foreground'
                                    onClick={restoreAllColumns}
                                >
                                    \uC804\uCCB4 \uBCF4\uAE30
                                </button>
                            </div>
                            <div className='max-h-56 space-y-2 overflow-auto'>
                                {columns.map((column) => (
                                    <label key={column.key} className='flex items-center gap-2 text-sm text-muted-foreground'>
                                        <input
                                            type='checkbox'
                                            checked={visibleColumns.has(column.key)}
                                            onChange={() => toggleColumnVisibility(column.key)}
                                        />
                                        <span>{column.header}</span>
                                    </label>
                                ))}
                            </div>
                        </div>
                    </details>

                    <Button variant='outline' size='sm' onClick={onRefresh} disabled={!onRefresh}>
                        \uC0C8\uB85C\uACE0\uCE68
                    </Button>
                    <Button variant='outline' size='sm' onClick={handleCsvExport}>
                        CSV
                    </Button>
                    <Button variant='outline' size='sm' onClick={handleExcelExport}>
                        \uC5D1\uC140
                    </Button>
                    {selectable ? (
                        <Button variant='ghost' size='sm' onClick={clearSelection} disabled={selectedRows.length === 0}>
                            \uC120\uD0DD \uD574\uC81C
                        </Button>
                    ) : null}
                </div>
            </div>

            <AgGridReact
                ref={gridRef}
                theme={gridTheme}
                rowData={rows}
                columnDefs={columnDefs}
                autoSizeStrategy={{
                    type: 'fitGridWidth',
                    defaultMinWidth: 120,
                }}
                localeText={KOREAN_LOCALE_TEXT}
                domLayout='autoHeight'
                rowSelection={
                    selectable
                        ? { mode: 'multiRow', checkboxes: true, headerCheckbox: true }
                        : undefined
                }
                onSortChanged={onSortChanged}
                onSelectionChanged={onSelectionChanged}
                onRowClicked={(event) => onRowClick?.(event.data)}
                suppressCellFocus
                suppressRowClickSelection={selectable}
                rowHeight={densityParams.rowHeight}
                headerHeight={densityParams.headerHeight}
            />

            {pageData ? (
                <footer
                    data-testid='grid-footer'
                    className='grid grid-cols-[1fr_auto_1fr] items-center gap-3 border-t border-border px-4 py-3'
                >
                    <div />
                    <div className='flex flex-wrap items-center justify-center gap-1'>
                        {pageItems.map((item) =>
                            item.type === 'ellipsis' ? (
                                <span key={item.key} className='px-2 text-sm text-muted-foreground'>
                                    ...
                                </span>
                            ) : (
                                <Button
                                    key={item.value}
                                    variant={item.value === pageData.page ? 'default' : 'outline'}
                                    size='sm'
                                    className={cn(
                                        'min-w-9 px-3',
                                        item.value === pageData.page && 'pointer-events-none',
                                    )}
                                    aria-current={item.value === pageData.page ? 'page' : undefined}
                                    onClick={() => onPageChange?.({ page: item.value, size: pageData.size })}
                                >
                                    {item.value}
                                </Button>
                            ),
                        )}
                    </div>
                    <div className='text-right text-sm text-muted-foreground'>
                        {`\uD398\uC774\uC9C0 ${pageData.page} / ${pageData.totalPages} \u00B7 \uCD1D ${pageData.totalElements}\uAC74`}
                    </div>
                </footer>
            ) : null}
        </section>
    );
};
