    <div class="bar-arrow"><div class="bar-line"></div><div class="bar-proto">Plugin API</div></div>
    <div class="comp-node"><div class="comp-badge cb-llm">LLM PLUGIN</div><div class="comp-label">Grafana Plugin</div></div>
    <div class="bar-arrow"><div class="bar-line"></div><div class="bar-proto">:11434/v1</div></div>
