    <div class="comp-node"><div class="comp-badge cb-result">DASHBOARD</div><div class="comp-label">시각화</div></div>
  </div>

  <div class="steps">
    <div class="step">
      <div class="step-connector"><div class="step-dot dot-act">1</div><div class="step-line"></div></div>
      <div class="step-body"><div class="step-card">
        <div class="step-head">
