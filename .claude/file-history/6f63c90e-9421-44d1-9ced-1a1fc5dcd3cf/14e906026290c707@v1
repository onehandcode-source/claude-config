	 /**
	 *
	 * @param commandMap
	 *
	 * @exception Exception
	 *                Exception
	 * desc: 다중파일을 EgovFormBasedFileVo객체로 리턴한다.
	 */
	public List<EgovFormBasedFileVo> multiFileAttrToVo(Map<String, Object> commandMap){
		List<EgovFormBasedFileVo> resultVo = new ArrayList();
		/************** 프로그램 로직 **************/
		//
		String[] fileName = null;
		String[] contentType = null;
		String[] physicalName = null;
		String[] serverSubPath = null;
		String[] size = null;
		String[] fieldName = null;
	
	
		fileName = commandMap.get("fileName").toString().split(",");
		contentType = commandMap.get("contentType").toString().split(",");
		physicalName = commandMap.get("physicalName").toString().split(",");
		serverSubPath = commandMap.get("serverSubPath").toString().split(",");
		size = commandMap.get("size").toString().split(",");
		fieldName = commandMap.get("fieldName").toString().split(",");
	
	
		for(int i=0; i<fileName.length; i++){
			EgovFormBasedFileVo tmpVo = new EgovFormBasedFileVo();
			tmpVo.setFileName(fileName[i]);
			tmpVo.setContentType(contentType[i]);
			tmpVo.setPhysicalName(physicalName[i]);
			tmpVo.setServerSubPath(serverSubPath[i]);
			tmpVo.setSize(Long.parseLong(size[i]));
			tmpVo.setFieldName(fieldName[i]);
			resultVo.add(tmpVo);
	
		}
	
		return resultVo;
	
	}


