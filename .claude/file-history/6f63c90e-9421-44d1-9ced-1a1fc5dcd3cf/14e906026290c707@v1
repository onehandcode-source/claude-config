	@Override
	public Map<String, String> getCrdnFileFullpath(Map<String, Object> commandMap) {

		Map<String, String> rtnMap = new HashMap<String, String>();
		// 캠코더 교통 단속은 첨부파일이 필수이기 때문에 인코딩 여부만 조회
		// 1. 파일 인코딩 여부 확인
		String encodeYn = atchFileMapper.getCrdnAllFileEncodeYn(commandMap);
		if(StringUtils.equals(encodeYn, "N")) {
			// 첨부파일에 대한 인코딩 여부 확인
			// P OR T 가 하나라도 있는 경우 인코딩 진행중 표출
			// T의 경우 압축 재요청 데몬이 10분에 15건씩 압축 요청 진행
			// 실패율 확인 추후 조정 필요
			rtnMap.put("fileResType", "02"); // 인코딩 진행중
			rtnMap.put("sourceFiles", "[]");
			return rtnMap;
		}

		List<HashMap<String, Object>> fileList = new ArrayList<HashMap<String, Object>>();
		fileList = atchFileMapper.getCrdnFileFullpath(commandMap);

		return makeFileJson(fileList);
	}
	
	// filepresso에 전달할 인코딩 완료된 첨부파일 파라미터 json 형태로 생성
	private Map<String, String> makeFileJson(List<HashMap<String, Object>> fileList) {
		
		Map<String, String> rtnMap = new HashMap<String, String>();
		Map<String, Map<String, Object>> fileMap = new LinkedHashMap<>();
 
		// fileName 기준으로 json 형태의 배열로 만드는 작업 
		for (HashMap<String, Object> file: fileList) {
			String fileName = MapUtils.getString(file, "NAME", "");

			if (!fileMap.containsKey(fileName)) {
				Map<String, Object> fileData = new LinkedHashMap<>(); 
				fileData.put("name", MapUtils.getString(file, "NAME", ""));
				fileData.put("type", MapUtils.getString(file, "TYPE", ""));
				fileData.put("originalUrl", MapUtils.getString(file, "ORIGINALURL", ""));
				fileData.put("localUrls", new ArrayList<String>());
				fileData.put("dmndYn", MapUtils.getString(file, "DMNDYN", ""));
				fileData.put("encYn", MapUtils.getString(file, "ENCYN", ""));
				fileMap.put(fileName, fileData);
			}
			// 한개의 영상 파일에서 트랜스 코딩 후 여러개로 나눠진 파일을 원본파일명 기준으로 배열 형태로 변경하여 localUrls에 맵핑
			/* localUrls: [
				"/wwwroot/html/files/2021-0818000308__00.mp4",
				"/wwwroot/html/files/2021-0818000308__01.mp4",
			] */
			Map<String, Object> fileData = fileMap.get(fileName);
			List<String> localUrls = (List<String>) fileData.get("localUrls");
			localUrls.add(MapUtils.getString(file, "LOCALURL", ""));
		}
		// JSON 문자열로 변환
		String json = new Gson().toJson(new ArrayList<>(fileMap.values()));
		rtnMap.put("sourceFiles", json.replace("\\\\", "/"));
		rtnMap.put("fileResType", "00"); // 인코딩 완료 
		
		return rtnMap;
	}
	
