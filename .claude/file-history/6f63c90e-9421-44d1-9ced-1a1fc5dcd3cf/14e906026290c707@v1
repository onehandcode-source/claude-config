    @Override
    public boolean selectSingoFileExist(Map<String, Object> commandMap) throws ParseException {
		try {
			List<HashMap<String, Object>> result = atchFileMapper.selectSingoFileList(commandMap);
			return result.stream().anyMatch(this::isExpiredSingoFile);
		} catch (Exception e) {
			logger.error("파일복원 체크 중 오류 발생: ", e);
			return false;
		}
	}

	private boolean isExpiredSingoFile(HashMap<String, Object> fileInfo) {
		String drctryPath = MapUtils.getString(fileInfo, "DRCTRY_PATH");
		String streFileNm = MapUtils.getString(fileInfo, "STRE_FILE_NM");

		// 파일 존재 여부 확인.
		File file = new File(drctryPath + streFileNm);
        // 파일 없음 -> 복원 버튼 노출
        return !file.exists() || file.length() <= 0; // 파일 있음 -> 복원 버튼 필요 없음
    }

