        Calendar calendar = Calendar.getInstance();
        String mon="";
        int iMon = calendar.get(Calendar.MONTH)+1;
        if(iMon<10){
            mon = "0"+String.valueOf(iMon);
        }else{
            mon = String.valueOf(iMon);
        }
        String day="";
        int iDay = calendar.get(Calendar.DAY_OF_MONTH);
        if(iDay<10){
            day = "0"+String.valueOf(iDay);
        }else{
            day = String.valueOf(iDay);
        }
        String fileDirectory = calendar.get(Calendar.YEAR)+"/"+mon+"/"+day+"/";

        uploadDirectory = uploadFilePath+fileDirectory;
        File uploadDirFile = new File(uploadDirectory);
        if(uploadDirFile.exists() == false){
            uploadDirFile.mkdirs();
            //SafeReportUtil.setFileAuth(uploadDirectory);
            FileUtil.setFileAuth(uploadDirectory);
        }

        String storedFileName = fileDirectory.replaceAll("/", "")+"_"+UUID.randomUUID().toString().replaceAll("-", "")+"."+originalFileName.substring(originalFileName.lastIndexOf(".") + 1);
        File saveFile = new File(uploadDirectory + storedFileName);
        file.transferTo(saveFile);

        fileMap.put("DRCTRY_PATH", fileDirectory);
        fileMap.put("ORGINL_FILE_NM", originalFileName);
        fileMap.put("STRE_FILE_NM", storedFileName);
        fileMap.put("FILE_SIZE", file.getSize());
        fileMap.put("FILE_TY", fileType);   // 파일 유형 변경(0:금지, 1:이미지, 2:동영상, 3:일반파일, 4:문서파일, 8:신고지도, 9:주요처리사례(노출이미지 아님) )
        //fileMap.put("FILE_URL", CommonConstant.TMP_FILE_PATH_TARGET + fileDirectory + storedFileName);
        fileMap.put("FILE_URL", CommProperties.getProperty("Globals.TMP_FILE_PATH_TARGET") + fileDirectory + storedFileName);
        fileMap.put("FILE_STATUS", "I");

        fileList.add(fileMap);

        return fileList;
    }

