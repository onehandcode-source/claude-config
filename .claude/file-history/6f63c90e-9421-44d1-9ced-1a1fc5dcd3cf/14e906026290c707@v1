    /**
	 * 첨부파일 불러오기(백업망 -> 업무망 -> 인터넷망)
	 */
    @Override
    @Transactional(value="txManager")
    public String updateSingoAttachFilesCopy(HashMap<String, Object> paramMap){
		try {
			List<HashMap<String, Object>> fileList = atchFileMapper.selectSingoFileList(paramMap);
			if (fileList == null || fileList.isEmpty()) {
				return "첨부파일이 존재하지 않습니다. 관리자에게 문의하십시오.";
			}

			int totalCnt = fileList.size();
			final AtomicInteger uCnt = new AtomicInteger(0);

			// 허용되는 이전 상태값 정의 (2:전송완료, 3:실패, 4:최종실패, 6:복원완료)
			List<Integer> allowedStatuses = Arrays.asList(2, 3, 4, 6);

			fileList.stream()
				.map(file -> MapUtils.getInteger(file, "C_NO"))
				.filter(Objects::nonNull)
				.forEach(cNo -> {
					Optional<FileSyncMngVO> vo = fileSyncMngMapper.selectFileSyncMng2(cNo);

					// 상태 업데이트를 위한 Dto 구성 (업무망 복원 중: 7)
					FileSyncMngDto updateDto = new FileSyncMngDto();
					updateDto.setFileQCNo(cNo);
					updateDto.setQueueStt(7);
					updateDto.setcId(MapUtils.getString(paramMap, "userId"));
					updateDto.setcRelation(1);

					if (!vo.isPresent()) {
						// 3-1. 데이터가 없으면 insert
						fileSyncMngMapper.insertFileSyncMng(updateDto);
					} else {
						FileSyncMngVO actualVo = vo.get();

						// 1. 이미 진행 중이거나(1) 복원 요청된(7) 상태면 건너뜀 (중복 방지)
						if (actualVo.getQueueStt() == 1 || actualVo.getQueueStt() == 7) {
							uCnt.incrementAndGet();
							return;
						}

						// 2. 특정 상태값(2, 3, 4, 6)일 때만 업데이트 수행
						if (!allowedStatuses.contains(actualVo.getQueueStt())) {
							uCnt.incrementAndGet();
							return;
						}

						// 3-2. 데이터가 있으면 update
						fileSyncMngMapper.updateFileSyncMng2(updateDto);
					}
				});

			// 3. 결과 코드 반환
			if (uCnt.get() == totalCnt) {
				return "복원중 입니다 잠시만 기다려 주세요."; 	// 이미 복원요청중
			} else if (uCnt.get() > 0) {
				return "복원중 입니다 잠시만 기다려 주세요."; 	// 일부 복원 중 포함됨 (나머지는 요청 완료)
			} else {
				return "첨부파일을 불러오고 있습니다. 약 5분 후 다시 확인하여 주시기 바랍니다.";		// 복원 대상
			}

		} catch (Exception e) {
			logger.error("복원 프로세스 중 오류 발생: {}", e.getMessage());
			return "문제가 발생하였습니다. 관리자에게 문의하십시요.";
		}
    }
    
	// 자동차 교통 위반 신고 첨부파일(미디어, 사진) 인코딩 완료 여부 및 목록 조회
	@Override
	public Map<String, String> getTrfcFileFullpath(Map<String, Object> commandMap) {
		
		Map<String, String> rtnMap = new HashMap<String, String>();
		// 1. 파일 첨부 여부 확인
		int cnt = atchFileMapper.getAttachFileCnt(commandMap);
		
		if(cnt == 0) {
			// 첨부파일이 없는 경우
			rtnMap.put("fileResType", "01"); // 첨부파일 없음
			rtnMap.put("sourceFiles", "[]");
			return rtnMap;
		} else {
			// 2. 파일 인코딩 여부 확인
			String encodeYn = atchFileMapper.getTrfcAllFileEncodeYn(commandMap);
			if(StringUtils.equals(encodeYn, "N")) {
				// 첨부파일에 대한 인코딩 여부 확인
				// P OR T 가 하나라도 있는 경우 인코딩 진행중 표출
				// T의 경우 압축 재요청 데몬이 10분에 15건씩 압축 요청 진행
				// 실패율 확인 추후 조정 필요
				rtnMap.put("fileResType", "02"); // 인코딩 진행중
				rtnMap.put("sourceFiles", "[]");
				return rtnMap;
			}
		}
		
		// 첨부파일의 인코딩이 완료된 경우 목록 조회 해서 json으로 만들기
		List<HashMap<String, Object>> fileList = atchFileMapper.getTrfcFileFullpath(commandMap);
		
		return makeFileJson(fileList);
	}
	

