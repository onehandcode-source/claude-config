	/**
	 * 파일 수정
	 * @param Map
	 * @exception Exception Exception
	 */
	@Override
	@Transactional(value="txManager")
	public HashMap<String, Object> updAtchFile(HttpServletRequest request, HttpServletResponse response,  String addPath, String tgrt_id) throws Exception {
		HashMap<String, Object> fileMap = new HashMap<String, Object>();

		//파일 업로드
		EgovFileUploadUtil egovFileUploadUtil = new EgovFileUploadUtil();
		List<EgovFormBasedFileVo> fileList = egovFileUploadUtil.uploadFiles(request, response, addPath);

		if(fileList != null){
			HashMap<String, Object> map = new HashMap<String, Object>();
			for(int i=0; i<fileList.size(); i++){
				map.put("ATCH_ID", request.getParameter("ATCH_ID"));
				map.put("UPD_IP", request.getRemoteAddr());
				map.put("ATCH_NM", fileList.get(i).getFileName());
				map.put("ATCH_TYP", fileList.get(i).getContentType());
				map.put("TGRT_NM", addPath);
				map.put("ATCH_SYS_NM", fileList.get(i).getPhysicalName());
				map.put("ATCH_SZ", fileList.get(i).getSize());
				map.put("TGRT_ID", StringUtil.noNull(tgrt_id));

				//DB저장
				int resultInt = (Integer)atchFileMapper.updAtchFile(map);

				fileMap.put(fileList.get(i).getFieldName(), resultInt);

			}
		}

		return fileMap;
	}
